<Page x:Class="DllSidecar.GUI.Views.BuildPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ctrl="clr-namespace:DllSidecar.GUI.Controls"
      Background="{StaticResource Base}">
    <Grid>
    <Grid Margin="28,20,28,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Build Project" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Text}"/>
            <TextBlock FontSize="12" Foreground="{StaticResource Overlay}" Margin="0,4,0,0" TextWrapping="Wrap"
                       Text="Compile a previously generated C project directory (Tracer, Proxy or Sideload) with MinGW-w64. Produces the final DLL ready to drop. Pick a project directory and press Build — auto-detects x64/x86 from the .c source."/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock Text="PROJECT DIRECTORY" Style="{StaticResource SectionHeader}" Margin="0,0,0,6"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="DirBox" FontFamily="{StaticResource FontMono}"/>
                <Button Grid.Column="1" Content="&#x1F4C1;" Style="{StaticResource IconButton}"
                        Margin="10,0,0,0" Click="BrowseDir_Click" ToolTip="Browse for project directory"/>
            </Grid>
        </StackPanel>

        <Border Grid.Row="2" x:Name="ResultPanel" Style="{StaticResource SectionCard}" Visibility="Collapsed">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" x:Name="ResultTitle" Text="BUILD OUTPUT"
                           Style="{StaticResource SectionHeader}"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="ResultText" Foreground="{StaticResource Text}"
                               FontFamily="{StaticResource FontMono}" FontSize="12" TextWrapping="Wrap"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Row="3" Background="{StaticResource Mantle}" CornerRadius="6" Padding="16,12" Margin="0,14,0,0">
            <Grid>
                <TextBlock x:Name="BuildStatus" HorizontalAlignment="Left" VerticalAlignment="Center"
                           FontFamily="{StaticResource FontMono}" FontSize="11"
                           Foreground="{StaticResource Overlay}" TextTrimming="CharacterEllipsis"
                           Text="Pick a generated project directory and press Build."/>
                <Button x:Name="BuildBtn" Content="Build"
                        Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right"
                        Padding="32,10" Click="Build_Click"/>
            </Grid>
        </Border>
    </Grid>
    <ctrl:LoadingOverlay x:Name="Overlay"/>
    </Grid>
</Page>
