<Page x:Class="DllSidecar.GUI.Views.InstallerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ctrl="clr-namespace:DllSidecar.GUI.Controls"
      Background="{StaticResource Base}">
    <Grid>
    <Grid Margin="28,20,28,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Installer Extraction" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource Text}"/>
            <TextBlock Foreground="{StaticResource Overlay}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap">
                <Run Text="Statically extract a .msi or .exe installer WITHOUT executing it — no custom actions, no registry writes, no sandbox needed. Tries in sequence: 7-Zip → msiexec /a → innounp. Output lands in "/>
                <Run Text="%LOCALAPPDATA%\DllSidecar\extracted\"
                     FontFamily="Cascadia Mono,Consolas" Foreground="{StaticResource Subtext}"/>
                <Run Text=" · once extracted you can jump straight to Scan Directory."/>
            </TextBlock>
        </StackPanel>

        <!-- Picker -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="InstallerPathBox" Grid.Column="0" FontFamily="Cascadia Mono,Consolas"
                    />
            <Button Grid.Column="1" Content="&#x1F4C1;" Style="{StaticResource IconButton}"
                    Margin="10,0,0,0" Click="Browse_Click" ToolTip="Browse for installer (.exe / .msi)"/>
            <Button Grid.Column="2" x:Name="ExtractBtn" Content="EXTRACT"
                    Style="{StaticResource TerminalButton}" Margin="10,0,0,0" Click="Extract_Click"/>
            <Button Grid.Column="3" x:Name="CancelBtn" Content="Cancel"
                    Style="{StaticResource DangerButton}" Margin="10,0,0,0"
                    Click="Cancel_Click" IsEnabled="False" Visibility="Collapsed"/>
        </Grid>

        <!-- Summary card -->
        <Border Grid.Row="2" x:Name="SummaryCard" Style="{StaticResource SectionCard}"
                Visibility="Collapsed" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="EXTRACTION RESULT" Style="{StaticResource SectionHeader}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Method:"    Foreground="{StaticResource Subtext}" Margin="0,2,14,2"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SumMethod"    Foreground="{StaticResource Text}" FontFamily="Cascadia Mono,Consolas" Margin="0,2"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Output dir:" Foreground="{StaticResource Subtext}" Margin="0,2,14,2"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SumOutput"    Foreground="{StaticResource Text}" FontFamily="Cascadia Mono,Consolas" Margin="0,2" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Files:"      Foreground="{StaticResource Subtext}" Margin="0,2,14,2"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="SumFiles"     Foreground="{StaticResource Text}" FontFamily="Cascadia Mono,Consolas" Margin="0,2"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Total size:" Foreground="{StaticResource Subtext}" Margin="0,2,14,2"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="SumSize"      Foreground="{StaticResource Text}" FontFamily="Cascadia Mono,Consolas" Margin="0,2"/>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button x:Name="ScanBtn" Content="Scan extracted" Style="{StaticResource PrimaryButton}"
                            Click="Scan_Click" IsEnabled="False"/>
                    <Button x:Name="OpenFolderBtn" Content="Open folder" Style="{StaticResource SecondaryButton}"
                            Margin="8,0,0,0" Click="OpenFolder_Click" IsEnabled="False"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Log -->
        <Border Grid.Row="3" Style="{StaticResource SectionCard}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="EXTRACTION LOG" Style="{StaticResource SectionHeader}"/>
                <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="LogBox" IsReadOnly="True" Background="Transparent"
                             Foreground="{StaticResource Text}" BorderThickness="0"
                             FontFamily="Cascadia Mono,Consolas" FontSize="11"
                             TextWrapping="Wrap" AcceptsReturn="True"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Footer -->
        <TextBlock Grid.Row="4" x:Name="Status" Foreground="{StaticResource Overlay}" FontSize="12"
                   Margin="0,10,0,0"
                   Text="Pick an installer to extract. Safer than running it — no custom actions executed."/>
    </Grid>
    <ctrl:LoadingOverlay x:Name="Overlay"/>
    </Grid>
</Page>
