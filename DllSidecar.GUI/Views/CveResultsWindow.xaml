<Window x:Class="DllSidecar.GUI.Views.CveResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:DllSidecar.GUI.Controls"
        Title="CVE dedup — NVD query"
        Width="860" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Base}"
        FontFamily="{StaticResource FontSans}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">
    <Grid>
    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock x:Name="HeaderTitle" Text="CVE dedup results"
                       FontSize="22" FontWeight="Bold" Foreground="{StaticResource Text}"/>
            <TextBlock x:Name="HeaderSubtitle" FontSize="12" Foreground="{StaticResource Overlay}"
                       Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Warning banner if exact match -->
        <Border Grid.Row="1" x:Name="WarningBanner" Visibility="Collapsed"
                Background="#33FF5B4F" BorderBrush="#FF5B4F" BorderThickness="1"
                CornerRadius="6" Padding="14,10" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock x:Name="WarningTitle" Foreground="#FF9085"
                           FontWeight="Bold" FontSize="13" FontFamily="{StaticResource FontMono}"/>
                <TextBlock x:Name="WarningDetail" Foreground="{StaticResource Text}"
                           FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Stats bar -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                    BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="EXACT" FontSize="10" FontWeight="Medium"
                               FontFamily="{StaticResource FontMono}" Foreground="{StaticResource Overlay}"/>
                    <TextBlock x:Name="StatExact" Text="0" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource Red}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                    BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="3,0">
                <StackPanel>
                    <TextBlock Text="LIKELY" FontSize="10" FontWeight="Medium"
                               FontFamily="{StaticResource FontMono}" Foreground="{StaticResource Overlay}"/>
                    <TextBlock x:Name="StatLikely" Text="0" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource Yellow}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                    BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="3,0">
                <StackPanel>
                    <TextBlock Text="RELATED" FontSize="10" FontWeight="Medium"
                               FontFamily="{StaticResource FontMono}" Foreground="{StaticResource Overlay}"/>
                    <TextBlock x:Name="StatRelated" Text="0" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource Blue}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                    BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="6,0,0,0">
                <StackPanel>
                    <TextBlock Text="TOTAL NVD HITS" FontSize="10" FontWeight="Medium"
                               FontFamily="{StaticResource FontMono}" Foreground="{StaticResource Overlay}"/>
                    <TextBlock x:Name="StatTotal" Text="0" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource Text}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Matches list -->
        <Border Grid.Row="3" Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                BorderThickness="1" CornerRadius="6" Padding="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="MatchesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource Surface0}" CornerRadius="6"
                                    Padding="14,10" Margin="4,3">
                                <StackPanel>
                                    <!-- First row: CVE-ID + confidence badge + CVSS -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding CveId}"
                                                   Foreground="{StaticResource Text}" FontWeight="Bold"
                                                   FontFamily="Cascadia Mono,Consolas" FontSize="13"/>
                                        <Border Grid.Column="1" Background="{Binding ConfidenceBg}" CornerRadius="999"
                                                Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ConfidenceLabel}" Foreground="{Binding ConfidenceFg}"
                                                       FontSize="10" FontWeight="Bold"
                                                       FontFamily="Cascadia Mono,Consolas"/>
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="{Binding CvssText}"
                                                   Foreground="{StaticResource Subtext}"
                                                   FontFamily="Cascadia Mono,Consolas" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- Meta line: vendor/product · published · CWEs -->
                                    <TextBlock Text="{Binding MetaLine}" Foreground="{StaticResource Overlay}"
                                               FontFamily="Cascadia Mono,Consolas" FontSize="10" Margin="0,3,0,6"
                                               TextWrapping="Wrap"/>
                                    <!-- Description -->
                                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource Text}"
                                               FontSize="12" TextWrapping="Wrap"/>
                                    <!-- Match reasons -->
                                    <TextBlock Text="{Binding ReasonsLine}" Foreground="{StaticResource Subtext}"
                                               FontSize="10" FontStyle="Italic" Margin="0,6,0,0"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding ReasonsVisibility}"/>
                                    <!-- Actions -->
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Content="Open in NVD" Style="{StaticResource SecondaryButton}"
                                                Tag="{Binding NvdUrl}" Click="OpenUrl_Click"/>
                                        <Button Content="Copy CVE ID" Style="{StaticResource GhostButton}"
                                                Margin="6,0,0,0" Tag="{Binding CveId}" Click="CopyCve_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <TextBlock x:Name="FooterStatus" HorizontalAlignment="Left" VerticalAlignment="Center"
                       Foreground="{StaticResource Overlay}" FontSize="11"
                       FontFamily="Cascadia Mono,Consolas" TextTrimming="CharacterEllipsis"/>
            <Button Content="Close" Style="{StaticResource SecondaryButton}"
                    HorizontalAlignment="Right" Click="Close_Click"/>
        </Grid>
    </Grid>
    <ctrl:LoadingOverlay x:Name="Overlay"/>
    </Grid>
</Window>
