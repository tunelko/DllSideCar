<Page x:Class="DllSidecar.GUI.Views.WelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource Base}">
    <Grid>
        <StackPanel Margin="40,32" MaxWidth="780" HorizontalAlignment="Left" VerticalAlignment="Top">
            <TextBlock Text="Welcome to DllSidecar"
                       FontSize="26" FontWeight="Bold"
                       Foreground="{StaticResource Text}"/>
            <TextBlock Text="A guided workflow for DLL sideloading research — analyze, scan, plant, advisory."
                       FontSize="13" Foreground="{StaticResource Overlay}" Margin="0,6,0,24"/>

            <Border Style="{StaticResource SectionCard}" Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock Text="FIRST STEP — POINT THE APP AT YOUR TOOLCHAIN"
                               Style="{StaticResource SectionHeader}"/>
                    <TextBlock Margin="0,8,0,0" TextWrapping="Wrap"
                               Foreground="{StaticResource Text}" FontSize="13">
                        Before running the wizard, open <Run FontWeight="Bold">Configuration</Run>
                        and set the directories the app needs to find your tooling:
                    </TextBlock>
                    <StackPanel Margin="14,12,0,0">
                        <TextBlock Foreground="{StaticResource Text}" FontSize="12" Margin="0,2">
                            · MinGW / MSYS2 — needed to compile generated DLL proxies (default <Run FontFamily="{StaticResource FontMono}">C:\msys64\…</Run>).
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource Text}" FontSize="12" Margin="0,2">
                            · Sysinternals — Procmon + sigcheck used by the dynamic analysis and verdict surfaces.
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource Text}" FontSize="12" Margin="0,2">
                            · Optional: NVD API key for CVE dedup, x64dbg path, Dependencies GUI.
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Margin="0,12,0,0" TextWrapping="Wrap"
                               Foreground="{StaticResource Subtext}" FontSize="11">
                        You can revisit Configuration at any time from the Tools menu.
                        This screen only appears on a fresh install (or after an upgrade).
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCard}" Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock Text="THEN — START THE WIZARD"
                               Style="{StaticResource SectionHeader}"/>
                    <TextBlock Margin="0,8,0,0" TextWrapping="Wrap"
                               Foreground="{StaticResource Text}" FontSize="13">
                        The wizard walks you through Input → Survey → Verify → Pick → Craft → Report.
                        Each step persists, so you can close the app mid-flow and resume where you left off.
                    </TextBlock>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button x:Name="OpenConfigBtn" Content="Open Configuration →"
                        Style="{StaticResource AccentButton}"
                        Padding="18,8" FontSize="13"
                        Click="OpenConfig_Click"/>
                <Button x:Name="SkipBtn" Content="Skip — go to wizard"
                        Margin="14,0,0,0" Padding="18,8" FontSize="13"
                        Click="Skip_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
