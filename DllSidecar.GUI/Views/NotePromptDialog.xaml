<Window x:Class="DllSidecar.GUI.Views.NotePromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add note" Width="420" Height="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Base}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Add a timeline note" FontSize="14" FontWeight="Bold"
                   Foreground="{StaticResource Text}" Margin="0,0,0,10"/>
        <TextBox Grid.Row="1" x:Name="NoteBox" AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" MinHeight="90"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}" IsCancel="True" Click="Cancel_Click"/>
            <Button Content="Add" Style="{StaticResource AccentButton}" IsDefault="True"
                    Margin="8,0,0,0" Click="Apply_Click"/>
        </StackPanel>
    </Grid>
</Window>
