<Window x:Class="DllSidecar.GUI.Views.StatusPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change status" Width="420" Height="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Base}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Change advisory status" FontSize="14" FontWeight="Bold"
                   Foreground="{StaticResource Text}" Margin="0,0,0,12"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="New status:" VerticalAlignment="Center"
                       Foreground="{StaticResource Subtext}" Margin="0,0,8,0"/>
            <ComboBox x:Name="StatusCombo" Width="220">
                <ComboBoxItem Content="Draft"/>
                <ComboBoxItem Content="ReadyToReport"/>
                <ComboBoxItem Content="SentToVendor"/>
                <ComboBoxItem Content="Acknowledged"/>
                <ComboBoxItem Content="CveRequested"/>
                <ComboBoxItem Content="CveAssigned"/>
                <ComboBoxItem Content="Fixed"/>
                <ComboBoxItem Content="Public"/>
                <ComboBoxItem Content="Closed"/>
                <ComboBoxItem Content="Rejected"/>
            </ComboBox>
        </StackPanel>
        <StackPanel Grid.Row="2">
            <TextBlock Text="Note (optional):" Foreground="{StaticResource Subtext}" Margin="0,0,0,4"/>
            <TextBox x:Name="NoteBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                     VerticalScrollBarVisibility="Auto"/>
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}" IsCancel="True" Click="Cancel_Click"/>
            <Button Content="Apply" Style="{StaticResource AccentButton}" IsDefault="True"
                    Margin="8,0,0,0" Click="Apply_Click"/>
        </StackPanel>
    </Grid>
</Window>
