<Page x:Class="DllSidecar.GUI.Views.GeneratePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ctrl="clr-namespace:DllSidecar.GUI.Controls"
      Background="{StaticResource Base}">
    <Grid>
    <Grid Margin="28,20,28,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: title + subtitle on the left, technique switch on the right.
             The switch is the single source of truth for which technique we generate;
             the rest of the form (TARGET EXPORT panel visibility, page title/subtitle)
             reacts to it. -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock x:Name="PageTitle" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Text}"/>
                <TextBlock x:Name="PageSubtitle" FontSize="12" Foreground="{StaticResource Overlay}"
                           Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Technique" Foreground="{StaticResource Subtext}" FontSize="11"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Border Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                        BorderThickness="1" CornerRadius="6">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="ModeProxy" GroupName="DllTechnique"
                                     Style="{StaticResource SegmentedRadio}"
                                     Content="Proxy" IsChecked="True"
                                     Checked="ModeSwitch_Changed"
                                     ToolTip="Forward all exports to _orig.dll, fire payload from a chosen export"/>
                        <RadioButton x:Name="ModeSideload" GroupName="DllTechnique"
                                     Style="{StaticResource SegmentedRadio}"
                                     Content="Sideload"
                                     Checked="ModeSwitch_Changed"
                                     ToolTip="Stub DLL with no forwarding — payload fires from DllMain"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- DLL picker -->
        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="TARGET DLL" Style="{StaticResource SectionHeader}" Margin="0,0,0,6"/>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="DllPathBox" FontFamily="{StaticResource FontMono}"/>
                <Button Grid.Column="1" Content="&#x1F4C1;" Style="{StaticResource IconButton}"
                        Margin="10,0,0,0" Click="Browse_Click" ToolTip="Browse for target DLL"/>
            </Grid>
        </Grid>

        <!-- Deploy banner — visible when ScanPage handed off a phantom slot. The
             generated build .bat will copy + run + restore. Host EXE is editable:
             default = importer detected at scan, but you often want the upstream
             launcher (portable app, installer, orchestrator) instead. -->
        <Border Grid.Row="2" x:Name="DeployBanner" Visibility="Collapsed"
                Background="#1F00F0A3" BorderBrush="{StaticResource Phosphor}" BorderThickness="0,0,0,1"
                CornerRadius="6" Padding="14,10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="DEPLOY + RUN" Foreground="{StaticResource Phosphor}"
                               FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Bold"/>
                    <TextBlock x:Name="AutoModeText" Foreground="{StaticResource Phosphor}"
                               FontFamily="{StaticResource FontMono}" FontSize="11" Margin="0,4,0,0"
                               TextWrapping="Wrap" Visibility="Collapsed"/>
                    <!-- Arch override — static scan's majority vote sometimes picks the wrong arch
                         when a dir mixes x86 and x64 importers (MobaXterm's mx86_64b\bin\ mostly x86
                         with a few x64 stragglers). Let the researcher flip it. -->
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0" x:Name="ArchRow" Visibility="Collapsed">
                        <TextBlock Text="Arch:" Foreground="{StaticResource Subtext}"
                                   FontFamily="{StaticResource FontMono}" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Border Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                                BorderThickness="1" CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="ArchX86" GroupName="ArchOverride"
                                             Style="{StaticResource SegmentedRadio}"
                                             Content="x86" Checked="ArchToggle_Changed"/>
                                <RadioButton x:Name="ArchX64" GroupName="ArchOverride"
                                             Style="{StaticResource SegmentedRadio}"
                                             Content="x64" Checked="ArchToggle_Changed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="DeployDropText" Foreground="{StaticResource Subtext}"
                               FontFamily="{StaticResource FontMono}" FontSize="11" Margin="0,6,0,6"
                               TextWrapping="Wrap"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Host:" Foreground="{StaticResource Subtext}"
                                   FontFamily="{StaticResource FontMono}" FontSize="11"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="HostExeBox" FontFamily="{StaticResource FontMono}"
                                 FontSize="11" Padding="6,4"
                                 ToolTip="EXE launched after deploy. Default = IAT importer. Change to the upstream launcher if the importer is an internal binary that doesn't run standalone."/>
                        <Button Grid.Column="2" Content="&#x1F4C1;" Style="{StaticResource IconButton}"
                                Margin="6,0,0,0" Click="BrowseHost_Click" ToolTip="Browse for Host EXE"/>
                    </Grid>
                </StackPanel>
                <Button Grid.Column="1" Content="Clear" Style="{StaticResource GhostButton}"
                        Click="ClearDeploy_Click" VerticalAlignment="Top" Margin="10,0,0,0"
                        ToolTip="Drop the deploy/run context — generated .bat will compile only"/>
            </Grid>
        </Border>

        <!-- Configuration columns + output -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 3 columns: PAYLOAD/EXPORT/THREAD on the left, EVASION (with TUNING)
                     in the wider middle, EXECUTION + POST-PROCESSING on the right. -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Col 1: target/payload selection -->
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <Border Style="{StaticResource SectionCard}" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="PAYLOAD" Style="{StaticResource SectionHeader}"/>
                                <ComboBox x:Name="PayloadCombo" SelectedIndex="0" SelectionChanged="PayloadCombo_Changed">
                                    <ComboBoxItem Content="MessageBox PoC (safe, visual proof)"/>
                                    <ComboBoxItem Content="Execute command"/>
                                    <ComboBoxItem Content="Shellcode injection"/>
                                    <ComboBoxItem x:Name="SandboxEscapeItem"
                                                  Content="Sandbox escape (AppContainer — Acrobat/Office/Chromium)"
                                                  Visibility="Collapsed"
                                                  ToolTip="Cross-process inject into a less-restricted sibling (e.g. AcroCEF) + CreateProcessA on WinSta0\Default so cmd.exe appears on desktop. Required for AppContainer hosts where WinExec is blocked."/>
                                    <ComboBoxItem Content="Reverse shell (TCP cmd.exe — host/port in Config)"
                                                  ToolTip="WSASocket → connect → CreateProcessA(&quot;cmd.exe&quot;) with stdin/stdout/stderr piped to the socket. Listener side: nc -lvnp PORT. Configure host/port in Configuration → Payload Defaults."/>
                                </ComboBox>
                                <TextBlock x:Name="SandboxHint" Visibility="Collapsed" Margin="0,6,0,0"
                                           Foreground="{StaticResource Phosphor}" FontSize="11"
                                           TextWrapping="Wrap"
                                           Text="Sandboxed host detected — SandboxEscape recommended."/>
                                <TextBox x:Name="PayloadDataBox" Margin="0,8,0,0"
                                         FontFamily="{StaticResource FontMono}" Visibility="Collapsed"
                                         ToolTip="Command to execute. calc.exe / cmd.exe / cmd.exe /k whoami / full path etc."/>
                                <StackPanel x:Name="SandboxTargetsPanel" Visibility="Collapsed" Margin="0,8,0,0">
                                    <TextBlock Text="Inject targets (CSV)" Foreground="{StaticResource Subtext}" FontSize="10"/>
                                    <TextBox x:Name="SandboxTargetsBox" FontFamily="{StaticResource FontMono}"
                                             Text="AcroCEF.exe,AdobeCollabSync.exe"
                                             ToolTip="Sibling processes to try inject-escape into. Adobe default shown. Office: MsoSync.exe,msoxmlmf.exe. Edge: msedgewebview2.exe. First one that passes OpenProcess + VirtualAllocEx RWX test wins."/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCard}" Margin="0,0,0,10"
                                x:Name="ExportPanel" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="TARGET EXPORT" Style="{StaticResource SectionHeader}"/>
                                <ComboBox x:Name="ExportCombo" MaxDropDownHeight="240"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCard}" x:Name="ThreadPanel" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="THREAD MODE" Style="{StaticResource SectionHeader}"/>
                                <ComboBox x:Name="ThreadCombo" SelectedIndex="0">
                                    <ComboBoxItem Content="Calling thread (hijack, most reliable)"/>
                                    <ComboBoxItem Content="New thread (CreateThread)"/>
                                    <ComboBoxItem Content="Native thread (NtCreateThreadEx)"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Col 2: evasion (largest, internal 2-col with TUNING mini-card) -->
                    <StackPanel Grid.Column="1" Margin="8,0,8,0">
                        <Border Style="{StaticResource SectionCard}" Margin="0,0,0,10">
                            <!-- 2x2 grid mirrors the wizard's CraftStage:
                                 Row 0 = EVASION + TUNING labels on the same baseline
                                 Row 1 = boolean toggles | tuning mini-card. -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto" MinWidth="220"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="EVASION"
                                           Style="{StaticResource SectionHeader}"
                                           VerticalAlignment="Bottom"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="TUNING"
                                           Style="{StaticResource SectionHeader}"
                                           Margin="20,0,0,8" VerticalAlignment="Bottom"/>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,0">
                                    <CheckBox x:Name="ChkDInvoke" Content="DInvoke — PEB walk, clean IAT" Margin="0,5"/>
                                    <CheckBox x:Name="ChkSyscalls" Content="Direct syscalls (x64 only)" Margin="0,5"/>
                                    <CheckBox x:Name="ChkIndirectSyscalls" Content="Indirect syscalls — gadget jump into ntdll (x64 only)" Margin="0,5"/>
                                    <CheckBox x:Name="ChkEncrypt" Content="XOR string encryption" Margin="0,5"/>

                                    <!-- Real XOR key — this exact byte sequence ends up as
                                         g_xkey[32] inside the generated DLL. Auto-generate
                                         picks fresh bytes; the value displayed when the
                                         user clicks Generate is what gets embedded. -->
                                    <StackPanel x:Name="XorKeyRow" Margin="22,4,0,4" Visibility="Collapsed">
                                        <TextBlock Text="g_xkey[32] embedded into the generated DLL"
                                                   Foreground="{StaticResource Subtext}" FontSize="11" Margin="0,0,0,3"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" x:Name="XorKeyBox" IsReadOnly="True"
                                                     FontFamily="{StaticResource FontMono}" FontSize="11"
                                                     Padding="6,4"
                                                     ToolTip="The exact bytes embedded as static const unsigned char g_xkey[32] in the generated .c. Same on every PoC built from this page until Auto-generate is pressed."/>
                                            <Button Grid.Column="1" Content="Auto-generate"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Margin="8,0,0,0" Click="XorAutoGen_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Row="1" Grid.Column="1" Margin="20,0,0,0"
                                        Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                                        BorderThickness="1" CornerRadius="6" Padding="14,12"
                                        VerticalAlignment="Top">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Delay (ms)"
                                                   Foreground="{StaticResource Subtext}" FontSize="11"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="DelayBox" Text="0"
                                                 Padding="8,5"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Col 3: post-processing + execution -->
                    <StackPanel Grid.Column="2" Margin="8,0,0,0">
                        <Border Style="{StaticResource SectionCard}" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="POST-PROCESSING" Style="{StaticResource SectionHeader}"/>
                                <CheckBox x:Name="ChkCloneMeta" Content="Clone version info (metadata)" Margin="0,4"/>
                                <CheckBox x:Name="ChkStomp" Content="Timestamp stomping" Margin="0,4"/>
                                <CheckBox x:Name="ChkAutoBuild" Content="Compile after generation" Margin="0,4" IsChecked="True"/>
                            </StackPanel>
                        </Border>

                        <!-- Runtime / deploy options — only relevant when a deploy context
                             is handed off (phantom flow). Left visible always so the user can
                             pre-configure before hitting Generate Sideload from Scan. -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="EXECUTION" Style="{StaticResource SectionHeader}"/>
                                <CheckBox x:Name="ChkWriteProof" Content="Write proof file to %TEMP% (diagnostic)"
                                          IsChecked="True" Margin="0,4"
                                          ToolTip="Payload writes dllsidecar_proof_&lt;PID&gt;.txt to %TEMP%. Reliable when MessageBox is invisible (service desktop, X server)."/>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Pre-launch delay (s):"
                                               Foreground="{StaticResource Subtext}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="1" x:Name="PreLaunchDelayBox" Text="0"
                                             ToolTip="Seconds to wait between deploy and launch. 0 = immediate."/>
                                </Grid>
                                <TextBlock Text="Host wait strategy" Foreground="{StaticResource Subtext}"
                                           FontSize="11" Margin="0,10,0,4"/>
                                <Border Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                                        BorderThickness="1" CornerRadius="6" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="WaitBlock" GroupName="WaitStrategy"
                                                     Style="{StaticResource SegmentedRadio}"
                                                     Content="Block until exit" IsChecked="True"
                                                     Checked="WaitStrategy_Changed"
                                                     ToolTip="start /WAIT — user closes host to trigger cleanup"/>
                                        <RadioButton x:Name="WaitFire" GroupName="WaitStrategy"
                                                     Style="{StaticResource SegmentedRadio}"
                                                     Content="Fire-and-forget"
                                                     Checked="WaitStrategy_Changed"
                                                     ToolTip="start + timeout N + show proof file — cleanup auto after timeout"/>
                                    </StackPanel>
                                </Border>
                                <Grid Margin="0,6,0,0" x:Name="FireTimeoutRow" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Fire timeout (s):"
                                               Foreground="{StaticResource Subtext}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="1" x:Name="FireTimeoutBox" Text="15"
                                             ToolTip="Seconds to wait after launch before inspecting proof + cleaning up."/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Output preview -->
                <Border x:Name="OutputPanel" Style="{StaticResource SectionCard}" Margin="0,12,0,0" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="GENERATED FILES" Style="{StaticResource SectionHeader}" Foreground="{StaticResource Green}"/>
                        <TextBlock x:Name="OutputInfo" Foreground="{StaticResource Text}"
                                   FontFamily="{StaticResource FontMono}" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer: right-aligned Generate button -->
        <Border Grid.Row="4" Background="{StaticResource Mantle}" CornerRadius="6" Padding="16,12" Margin="0,14,0,0">
            <Grid>
                <TextBlock x:Name="GenStatus" HorizontalAlignment="Left" VerticalAlignment="Center"
                           FontFamily="{StaticResource FontMono}" FontSize="11"
                           Foreground="{StaticResource Overlay}" TextTrimming="CharacterEllipsis"/>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Content="Reset to Starter defaults" Style="{StaticResource SecondaryButton}" Click="Reset_Click"
                            ToolTip="Turn off DInvoke / syscalls / encryption, reset payload to MessageBox, thread to Calling — safe defaults for a first PoC"/>
                    <Button x:Name="GenerateBtn" Content="Generate"
                            Style="{StaticResource PrimaryButton}" Margin="10,0,0,0"
                            Padding="32,10" Click="Generate_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
    <ctrl:LoadingOverlay x:Name="Overlay"/>
    </Grid>
</Page>
