<Page x:Class="DllSidecar.GUI.Views.ConfigPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ctrl="clr-namespace:DllSidecar.GUI.Controls"
      Background="{StaticResource Base}">
    <Grid>
    <Grid Margin="28,20,28,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Configuration" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Text}"/>
            <TextBlock FontSize="12" Foreground="{StaticResource Overlay}" Margin="0,4,0,0" TextWrapping="Wrap"
                       Text="Persistent settings — toolchain paths, third-party tool locations, researcher identity, behaviour. Saved to %APPDATA%\DllSidecar\config.json on Save config."/>
        </StackPanel>

        <!-- Body: single column flow -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- MINGW TOOLCHAIN -->
                <Border x:Name="MingwSection" Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="MINGW TOOLCHAIN" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Bin directories for the GCC builds used by Generate / Build. x64 is required; x86 is needed for 32-bit targets like Battle.net Agent."
                                   FontSize="11" Foreground="{StaticResource Overlay}" Margin="0,0,0,8" TextWrapping="Wrap"/>

                        <ctrl:ToolPathRow x:Name="Mingw64Row" Label="MinGW-w64 x64 bin"
                                          Purpose="gcc.exe / windres.exe for 64-bit DLL compilation"/>
                        <ctrl:ToolPathRow x:Name="Mingw32Row" Label="MinGW-w64 x86 bin"
                                          Purpose="gcc.exe / windres.exe for 32-bit DLL compilation"/>
                        <ctrl:ToolPathRow x:Name="MsysRow"    Label="MSYS2 usr/bin"
                                          Purpose="Optional fallback (windres lives here on some setups)"/>

                        <Grid Margin="0,12,0,0">
                            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                <Button Content="Auto-detect" Style="{StaticResource SecondaryButton}" Click="AutoDetect_Click"
                                        ToolTip="Probe well-known MSYS2 / mingw-w64 install roots"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                <Button Content="&#x2713;  Validate toolchain" Style="{StaticResource AccentButton}" Click="Validate_Click"
                                        ToolTip="Run BuildSystem.FindGcc / FindWindres for both archs"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="ValidateStatus" FontFamily="{StaticResource FontMono}" FontSize="11"
                                   Foreground="{StaticResource Overlay}" Margin="0,12,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- TOOLS -->
                <Border x:Name="ToolsSection" Style="{StaticResource SectionCard}" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="TOOLS" Style="{StaticResource SectionHeader}"/>
                        <TextBlock FontSize="11" Foreground="{StaticResource Overlay}" Margin="0,0,0,8" TextWrapping="Wrap"
                                   Text="Bundle directories first (Sysinternals folder feeds Detect for ProcMon/sigcheck/etc.). Per-tool paths override or supplement bundle resolution. Optional rows can stay blank."/>

                        <!-- Bundle directories -->
                        <ctrl:ToolPathRow x:Name="SysinternalsRow" Label="Sysinternals folder"
                                          Purpose="Auto-resolves Procmon, sigcheck, psexec when set"/>
                        <ctrl:ToolPathRow x:Name="ToolsRootRow"    Label="Generic tools root"
                                          Purpose="Fallback root probed 1 level deep for known binaries"/>

                        <!-- Per-tool exes -->
                        <ctrl:ToolPathRow x:Name="ProcmonRow"      Label="ProcMon"             Purpose="Phase 2 — record NAME NOT FOUND DLL loads" IsRequired="True"/>
                        <ctrl:ToolPathRow x:Name="SigcheckRow"     Label="sigcheck"            Purpose="Cross-check Authenticode signatures"/>
                        <ctrl:ToolPathRow x:Name="DependenciesRow" Label="Dependencies (lucasg)" Purpose="Visual IAT / import tree browser"/>
                        <ctrl:ToolPathRow x:Name="X64DbgRow"       Label="x64dbg"              Purpose="Dynamic debug of 64-bit targets"/>
                        <ctrl:ToolPathRow x:Name="X32DbgRow"       Label="x32dbg"              Purpose="Dynamic debug of 32-bit targets"/>

                        <!-- NVD API key — not a path, kept here because it's a tools/external-resource secret -->
                        <TextBlock Text="NVD API key (optional — raises rate limit 5→50 req/30s)" Style="{StaticResource FieldLabel}" Margin="0,16,0,0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="NvdApiKeyBox" Grid.Column="0"
                                     FontFamily="{StaticResource FontMono}"
                                     ToolTip="Request at https://nvd.nist.gov/developers/request-an-api-key"/>
                            <Button Grid.Column="1" Content="Get key…" Style="{StaticResource SecondaryButton}"
                                    Margin="6,0,0,0" Click="GetNvdKey_Click"/>
                        </Grid>

                        <Button Content="Re-scan toolkit" Style="{StaticResource SecondaryButton}"
                                Margin="0,12,0,0" HorizontalAlignment="Right" Click="RescanToolkit_Click"
                                ToolTip="Run ToolkitChecker over the current saved config"/>
                    </StackPanel>
                </Border>

                <!-- RESEARCHER IDENTITY -->
                <Border x:Name="ResearcherSection" Style="{StaticResource SectionCard}" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="RESEARCHER IDENTITY" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Persisted in config.json (local). Used as default in advisory drafting; per-advisory overrides live in the advisory record."
                                   FontSize="11" Foreground="{StaticResource Overlay}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name"   Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Handle" Style="{StaticResource FieldLabel}" Margin="10,0,0,0"/>
                            <TextBox   Grid.Row="1" Grid.Column="0" x:Name="ResearcherNameBox"   FontFamily="{StaticResource FontMono}"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="ResearcherHandleBox" FontFamily="{StaticResource FontMono}" Margin="10,0,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Blog"  Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Email" Style="{StaticResource FieldLabel}" Margin="10,0,0,0"/>
                            <TextBox   Grid.Row="3" Grid.Column="0" x:Name="ResearcherBlogBox"  FontFamily="{StaticResource FontMono}"/>
                            <TextBox   Grid.Row="3" Grid.Column="1" x:Name="ResearcherEmailBox" FontFamily="{StaticResource FontMono}" Margin="10,0,0,0"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="PGP fingerprint (40 hex)" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="PGP key id (16 hex)" Style="{StaticResource FieldLabel}" Margin="10,0,0,0"/>
                            <TextBox   Grid.Row="5" Grid.Column="0" x:Name="PgpFingerprintBox" FontFamily="{StaticResource FontMono}"/>
                            <TextBox   Grid.Row="5" Grid.Column="1" x:Name="PgpKeyIdBox"       FontFamily="{StaticResource FontMono}" Margin="10,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" x:Name="IncibeOptInBox" Content="Opt in to INCIBE CVE ranking"
                                      Foreground="{StaticResource Text}" VerticalAlignment="Center"/>
                            <Grid Grid.Column="1" Margin="20,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="INCIBE public display name:"
                                           Foreground="{StaticResource Subtext}" VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" x:Name="IncibeDisplayNameBox" FontFamily="{StaticResource FontMono}"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- BEHAVIOR -->
                <Border x:Name="BehaviorSection" Style="{StaticResource SectionCard}" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="BEHAVIOR" Style="{StaticResource SectionHeader}"/>
                        <CheckBox x:Name="AutoCveLookupBox"
                                  Content="Auto CVE lookup after each scan (NVD)"
                                  Foreground="{StaticResource Text}" Margin="0,4,0,0"/>
                        <TextBlock Text="When checked, ScanPage queries NVD automatically. Off if you want to avoid traffic on repeated local scans."
                                   FontSize="11" Foreground="{StaticResource Overlay}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- PAYLOAD DEFAULTS -->
                <Border x:Name="PayloadSection" Style="{StaticResource SectionCard}" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="PAYLOAD DEFAULTS" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="MessageBox PoC popup text reused across every Generate run. Use {Researcher} as a placeholder — it's substituted at template time. Newlines are emitted as \n in the generated C; quotes are escaped automatically."
                                   FontSize="11" Foreground="{StaticResource Overlay}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <TextBlock Text="MessageBox title" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="MsgBoxTitleBox" FontFamily="{StaticResource FontMono}"
                                 ToolTip="Title bar text. Default: 'DllSidecar PoC {Researcher}'"/>
                        <TextBlock Text="MessageBox body" Style="{StaticResource FieldLabel}" Margin="0,10,0,0"/>
                        <TextBox x:Name="MsgBoxBodyBox" FontFamily="{StaticResource FontMono}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="70" MaxHeight="140"
                                 VerticalScrollBarVisibility="Auto"
                                 ToolTip="Body text. Multi-line is fine — every newline becomes \n in the generated C source."/>

                        <!-- Reverse shell endpoint: stays in Config (not Generate) because
                             the listener typically doesn't change between PoCs in the same
                             research session. Both fields parsed/applied at template time. -->
                        <TextBlock Text="Reverse shell — endpoint" Style="{StaticResource FieldLabel}" Margin="0,16,0,0"/>
                        <TextBlock Text="Reverse shell connect-back endpoint. Listener side: nc -lvnp PORT. Host accepts dotted-quad IPv4 (compiled inline, no DNS) or a hostname (resolved at runtime via inet_addr)."
                                   FontSize="11" Foreground="{StaticResource Overlay}" Margin="0,2,0,6" TextWrapping="Wrap"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Host" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="RevShellHostBox" FontFamily="{StaticResource FontMono}"
                                         ToolTip="IPv4 or hostname. Default: 127.0.0.1"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Port" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="RevShellPortBox" FontFamily="{StaticResource FontMono}"
                                         ToolTip="TCP port (1-65535). Default: 4444"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer: button bar right-aligned -->
        <Border Grid.Row="2" Background="{StaticResource Mantle}" CornerRadius="6" Padding="16,12" Margin="0,14,0,0">
            <Grid>
                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                    <TextBlock x:Name="SaveStatus" VerticalAlignment="Center"
                               FontFamily="{StaticResource FontMono}" FontSize="11"
                               Foreground="{StaticResource Overlay}" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Content="Open config folder" Style="{StaticResource SecondaryButton}" Click="OpenFolder_Click"/>
                    <Button Content="Reset defaults" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="Reset_Click"/>
                    <Button x:Name="SaveConfigBtn" Content="Save config" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Click="Save_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
    <ctrl:LoadingOverlay x:Name="Overlay"/>
    </Grid>
</Page>
