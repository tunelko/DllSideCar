<Page x:Class="DllSidecar.GUI.Views.Wizard.WizardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ctrl="clr-namespace:DllSidecar.GUI.Controls"
      Background="{StaticResource Base}">
    <Grid>
    <Grid Margin="28,20,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Research Wizard" FontSize="24" FontWeight="SemiBold"
                       Foreground="{StaticResource Text}"/>
            <TextBlock FontSize="12" Foreground="{StaticResource Overlay}" Margin="0,4,0,0" TextWrapping="Wrap"
                       Text="Input → survey → verify (opt.) → pick → craft → report. Each stage backed by its dedicated module."/>

        </StackPanel>

        <!-- Stage indicator -->
        <Border Grid.Row="1" Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,0,0,18">
            <ItemsControl x:Name="StepperItems">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel HorizontalAlignment="Center">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Connector line left -->
                                <Rectangle Grid.Column="0" Height="2" Fill="{Binding LeftConnector}"
                                           VerticalAlignment="Center" Visibility="{Binding LeftConnectorVisibility}"/>
                                <!-- Circle -->
                                <Grid Grid.Column="1" Width="28" Height="28">
                                    <Ellipse Fill="{Binding CircleFill}" Stroke="{Binding CircleStroke}" StrokeThickness="2"/>
                                    <TextBlock Text="{Binding StepLabel}" Foreground="{Binding NumberFg}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontFamily="{StaticResource FontMono}" FontSize="11" FontWeight="Bold"/>
                                </Grid>
                                <!-- Connector line right -->
                                <Rectangle Grid.Column="2" Height="2" Fill="{Binding RightConnector}"
                                           VerticalAlignment="Center" Visibility="{Binding RightConnectorVisibility}"/>
                            </Grid>
                            <TextBlock Text="{Binding Name}" Foreground="{Binding LabelFg}"
                                       FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Stage content (UserControls swapped in via code-behind) -->
        <Border Grid.Row="2" Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                BorderThickness="1" CornerRadius="8">
            <Grid>
                <ContentControl x:Name="StageHost" Margin="0"/>
            </Grid>
        </Border>

        <!-- Session summary strip -->
        <Border Grid.Row="3" Background="{StaticResource Crust}" BorderBrush="{StaticResource Ring}"
                BorderThickness="1" CornerRadius="6" Padding="14,8" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="SESSION" FontFamily="{StaticResource FontMono}" FontSize="10"
                           FontWeight="Medium" Foreground="{StaticResource Blue}"
                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                <TextBlock x:Name="SessionSummary" Foreground="{StaticResource Subtext}"
                           FontFamily="Cascadia Mono,Consolas" FontSize="11"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                           Text="(empty — no input yet)"/>
            </StackPanel>
        </Border>

        <!-- Nav footer -->
        <Grid Grid.Row="4" Margin="0,10,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button x:Name="DiscardBtn" Content="Discard &amp; restart" Style="{StaticResource GhostButton}"
                        Click="Discard_Click"/>
                <Button x:Name="BackBtn" Content="← Back" Style="{StaticResource SecondaryButton}"
                        Margin="8,0,0,0" Click="Back_Click"/>
                <Button x:Name="SkipBtn" Content="Skip" Style="{StaticResource SecondaryButton}"
                        Margin="8,0,0,0" Click="Skip_Click" Visibility="Collapsed"/>
                <Button x:Name="ContinueBtn" Content="Continue →" Style="{StaticResource PrimaryButton}"
                        Margin="8,0,0,0" Padding="26,8" Click="Continue_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
    <ctrl:LoadingOverlay x:Name="Overlay"/>
    </Grid>
</Page>
