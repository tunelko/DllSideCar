<UserControl x:Class="DllSidecar.GUI.Views.Wizard.Stages.CraftStage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20">
            <!-- Header: title on the left, mode tiles top-right.
                 Tiles act as page-level mode toggles, always visible without scrolling. -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Step 5 · Craft the PoC"
                           FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Text}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="TileProxy" Style="{StaticResource ActionTile}"
                            Width="160" Margin="0,0,8,0" Padding="12,8" Click="TileProxy_Click">
                        <StackPanel>
                            <TextBlock Text="&#x26A1;" FontSize="18" TextAlignment="Center"/>
                            <TextBlock Text="Proxy" FontSize="12" FontWeight="SemiBold" TextAlignment="Center"
                                       Foreground="{StaticResource Text}" Margin="0,3,0,1"/>
                            <TextBlock Text="forward + fire" FontSize="10" TextAlignment="Center"
                                       Foreground="{StaticResource Overlay}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="TileSideload" Style="{StaticResource ActionTile}"
                            Width="160" Padding="12,8" Click="TileSideload_Click">
                        <StackPanel>
                            <TextBlock Text="&#x1F4E6;" FontSize="18" TextAlignment="Center"/>
                            <TextBlock Text="Sideload" FontSize="12" FontWeight="SemiBold" TextAlignment="Center"
                                       Foreground="{StaticResource Text}" Margin="0,3,0,1"/>
                            <TextBlock Text="drop + run DllMain" FontSize="10" TextAlignment="Center"
                                       Foreground="{StaticResource Overlay}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
            <TextBlock x:Name="HeaderHint" FontSize="12" Foreground="{StaticResource Subtext}" Margin="0,0,0,14" TextWrapping="Wrap"/>

            <!-- Deploy banner — seeded from ResolveTarget. Arch toggle + host editor
                 mirror GeneratePage so the researcher can correct a bad majority vote
                 or redirect to the upstream launcher. -->
            <Border x:Name="DeployBanner"
                    Background="#1F00F0A3" BorderBrush="{StaticResource Phosphor}" BorderThickness="0,0,0,1"
                    CornerRadius="6" Padding="14,10" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="DEPLOY + RUN" Foreground="{StaticResource Phosphor}"
                               FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Bold"/>
                    <TextBlock x:Name="AutoModeText" Foreground="{StaticResource Phosphor}"
                               FontFamily="{StaticResource FontMono}" FontSize="11" Margin="0,4,0,0"
                               TextWrapping="Wrap" Visibility="Collapsed"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Arch:" Foreground="{StaticResource Subtext}"
                                   FontFamily="{StaticResource FontMono}" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Border Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                                BorderThickness="1" CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="ArchX86" GroupName="ArchOverride"
                                             Style="{StaticResource SegmentedRadio}"
                                             Content="x86" Checked="ArchToggle_Changed"/>
                                <RadioButton x:Name="ArchX64" GroupName="ArchOverride"
                                             Style="{StaticResource SegmentedRadio}"
                                             Content="x64" Checked="ArchToggle_Changed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="DeployDropText" Foreground="{StaticResource Subtext}"
                               FontFamily="{StaticResource FontMono}" FontSize="11" Margin="0,6,0,6"
                               TextWrapping="Wrap"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Host:" Foreground="{StaticResource Subtext}"
                                   FontFamily="{StaticResource FontMono}" FontSize="11"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="HostExeBox" FontFamily="{StaticResource FontMono}"
                                 FontSize="11" Padding="6,4"
                                 TextChanged="HostExeBox_Changed"
                                 ToolTip="EXE launched after deploy. Default = first arch-matching importer. Change if you want the upstream launcher."/>
                        <Button Grid.Column="2" Content="&#x1F4C1;" Style="{StaticResource IconButton}"
                                Margin="6,0,0,0" Click="BrowseHost_Click" ToolTip="Browse for Host EXE"/>
                    </Grid>
                    <TextBlock x:Name="HostWarning" Visibility="Collapsed" Margin="70,4,0,0"
                               Foreground="{StaticResource Yellow}" FontSize="10.5"
                               FontFamily="{StaticResource FontMono}" TextWrapping="Wrap"
                               Text="⚠ Looks like a temp-extracted path. The real launcher (portable EXE / installer / parent) probably lives elsewhere — override above."/>
                </StackPanel>
            </Border>

            <!-- Config: 3 stacked columns mirroring DLL Techniques (GeneratePage).
                 Col 1: PAYLOAD → TARGET EXPORT (proxy only) → THREAD MODE (proxy only)
                 Col 2: EVASION (wider; internal TUNING mini-card to its right)
                 Col 3: POST-PROCESSING → EXECUTION
                 EVASION column is the growth area — new techniques (AMSI hooks,
                 ETW patch, hellgate, etc.) plug in as more checkboxes here. -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Col 1: payload → target → thread mode -->
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <Border Style="{StaticResource SectionCard}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="PAYLOAD" Style="{StaticResource SectionHeader}"/>
                            <ComboBox x:Name="PayloadCombo" SelectedIndex="0" SelectionChanged="PayloadCombo_Changed">
                                <ComboBoxItem Content="MessageBox PoC (safe, visual proof)"/>
                                <ComboBoxItem Content="Execute command"/>
                                <ComboBoxItem Content="Shellcode injection"/>
                                <ComboBoxItem Content="Sandbox escape (AppContainer — Acrobat/Office/Chromium)"
                                              ToolTip="Cross-process inject into a less-restricted sibling + CreateProcessA on WinSta0\Default. Use for AppContainer hosts where WinExec is blocked."/>
                            </ComboBox>
                            <TextBox x:Name="PayloadDataBox" Margin="0,8,0,0"
                                     FontFamily="{StaticResource FontMono}" Visibility="Collapsed"
                                     ToolTip="Command to execute. calc.exe / cmd.exe / cmd.exe /k whoami / full path etc."/>
                            <StackPanel x:Name="SandboxTargetsPanel" Visibility="Collapsed" Margin="0,8,0,0">
                                <TextBlock Text="Inject targets (CSV)" Foreground="{StaticResource Subtext}" FontSize="10"/>
                                <TextBox x:Name="SandboxTargetsBox" FontFamily="{StaticResource FontMono}"
                                         Text="AcroCEF.exe,AdobeCollabSync.exe"
                                         ToolTip="Sibling processes to try inject-escape into. Adobe default. Office: MsoSync.exe,msoxmlmf.exe. Edge: msedgewebview2.exe."/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCard}" Margin="0,0,0,10"
                            x:Name="ExportPanel" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="TARGET EXPORT" Style="{StaticResource SectionHeader}"/>
                            <ComboBox x:Name="ExportCombo" MaxDropDownHeight="240"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCard}" x:Name="ThreadPanel" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="THREAD MODE" Style="{StaticResource SectionHeader}"/>
                            <ComboBox x:Name="ThreadCombo" SelectedIndex="0">
                                <ComboBoxItem Content="Calling thread (hijack, most reliable)"/>
                                <ComboBoxItem Content="New thread (CreateThread)"/>
                                <ComboBoxItem Content="Native thread (NtCreateThreadEx)"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Col 2: EVASION (wider, internal TUNING mini-card on the right) -->
                <StackPanel Grid.Column="1" Margin="8,0,8,0">
                    <Border Style="{StaticResource SectionCard}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" MinWidth="180"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="EVASION"
                                       Style="{StaticResource SectionHeader}"
                                       VerticalAlignment="Bottom"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="TUNING"
                                       Style="{StaticResource SectionHeader}"
                                       Margin="20,0,0,8" VerticalAlignment="Bottom"/>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,0">
                                <CheckBox x:Name="ChkDInvoke" Content="DInvoke — PEB walk, clean IAT" Margin="0,5"/>
                                <CheckBox x:Name="ChkSyscalls" Content="Direct syscalls (x64 only)" Margin="0,5"/>
                                <CheckBox x:Name="ChkEncrypt" Content="XOR string encryption" Margin="0,5"/>
                            </StackPanel>
                            <Border Grid.Row="1" Grid.Column="1" Margin="20,0,0,0"
                                    Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                                    BorderThickness="1" CornerRadius="6" Padding="14,12"
                                    VerticalAlignment="Top">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Delay (ms)"
                                               Foreground="{StaticResource Subtext}" FontSize="11"
                                               VerticalAlignment="Center" Margin="0,0,12,8"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="DelayBox" Text="0"
                                             Margin="0,0,0,8" Padding="8,5"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="XOR key"
                                               Foreground="{StaticResource Subtext}" FontSize="11"
                                               VerticalAlignment="Center" Margin="0,8,12,0"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="XorKeyCombo" Margin="0,8,0,0"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Col 3: post-processing + execution -->
                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                    <Border Style="{StaticResource SectionCard}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="POST-PROCESSING" Style="{StaticResource SectionHeader}"/>
                            <CheckBox x:Name="ChkCloneMeta" Content="Clone version info (metadata)" Margin="0,4"/>
                            <CheckBox x:Name="ChkStomp" Content="Timestamp stomping" Margin="0,4"/>
                            <CheckBox x:Name="ChkAutoBuild" Content="Compile DLL with MinGW" Margin="0,4" IsChecked="True"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="EXECUTION" Style="{StaticResource SectionHeader}"/>
                            <CheckBox x:Name="ChkWriteProof" Content="Write proof file to %TEMP%"
                                      IsChecked="True" Margin="0,4"
                                      ToolTip="Payload writes dllsidecar_proof_&lt;PID&gt;.txt to %TEMP%. Reliable when MessageBox is invisible."/>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Pre-launch delay (s):"
                                           Foreground="{StaticResource Subtext}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" x:Name="PreLaunchDelayBox" Text="0"/>
                            </Grid>
                            <TextBlock Text="Host wait strategy" Foreground="{StaticResource Subtext}"
                                       FontSize="11" Margin="0,10,0,4"/>
                            <Border Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                                    BorderThickness="1" CornerRadius="6" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="WaitBlock" GroupName="WaitStrategy"
                                                 Style="{StaticResource SegmentedRadio}"
                                                 Content="Block until exit" IsChecked="True"
                                                 Checked="WaitStrategy_Changed"/>
                                    <RadioButton x:Name="WaitFire" GroupName="WaitStrategy"
                                                 Style="{StaticResource SegmentedRadio}"
                                                 Content="Fire-and-forget"
                                                 Checked="WaitStrategy_Changed"/>
                                </StackPanel>
                            </Border>
                            <Grid Margin="0,6,0,0" x:Name="FireTimeoutRow" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Fire timeout (s):"
                                           Foreground="{StaticResource Subtext}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" x:Name="FireTimeoutBox" Text="15"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <TextBlock x:Name="StatusLine" Foreground="{StaticResource Overlay}" FontSize="11"
                       FontFamily="{StaticResource FontMono}" Margin="0,14,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
