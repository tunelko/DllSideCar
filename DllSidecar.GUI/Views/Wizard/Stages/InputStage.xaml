<UserControl x:Class="DllSidecar.GUI.Views.Wizard.Stages.InputStage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True">
    <UserControl.Resources>
        <!-- Entry card — large clickable tile for each of the three research entry
             points. Picked style matches ActionTile family but with a phosphor accent
             for the selected state. -->
        <Style x:Key="EntryCard" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="{StaticResource Surface0}"
                                BorderBrush="{StaticResource Ring}" BorderThickness="1"
                                CornerRadius="10" Padding="16,14" MinHeight="120">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource RingStrong}"/>
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Surface1}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Phosphor}"/>
                                <Setter TargetName="bd" Property="Background" Value="#1F00F0A3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Step 1 · Pick your entry point"
                   FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" FontSize="12" Foreground="{StaticResource Overlay}" Margin="0,0,0,16" TextWrapping="Wrap"
                   Text="Three ways to start. Pick one; the wizard routes the remaining stages accordingly."/>

        <!-- Three entry cards -->
        <Grid Grid.Row="2" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <RadioButton Grid.Column="0" x:Name="EntryScan" GroupName="Entry"
                         Style="{StaticResource EntryCard}" IsChecked="True"
                         Checked="Entry_Changed">
                <StackPanel>
                    <TextBlock Text="&#x1F4C1;" FontSize="28" Margin="0,0,0,8"/>
                    <TextBlock Text="Scan a folder" Foreground="{StaticResource Text}"
                               FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Foreground="{StaticResource Subtext}" FontSize="11" TextWrapping="Wrap"
                               Margin="0,4,0,0"
                               Text="Install directory or extracted installer. Runs IAT + phantom detection + scoring across every PE in the tree."/>
                </StackPanel>
            </RadioButton>

            <RadioButton Grid.Column="1" x:Name="EntryAnalyze" GroupName="Entry"
                         Style="{StaticResource EntryCard}" Checked="Entry_Changed">
                <StackPanel>
                    <TextBlock Text="&#x1F50D;" FontSize="28" Margin="0,0,0,8"/>
                    <TextBlock Text="Analyze a binary" Foreground="{StaticResource Text}"
                               FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Foreground="{StaticResource Subtext}" FontSize="11" TextWrapping="Wrap"
                               Margin="0,4,0,0"
                               Text="Single DLL/EXE. Skips scanning — goes straight to Pick with that PE as the resolved target."/>
                </StackPanel>
            </RadioButton>

            <RadioButton Grid.Column="2" x:Name="EntryRuntime" GroupName="Entry"
                         Style="{StaticResource EntryCard}" Checked="Entry_Changed">
                <StackPanel>
                    <TextBlock Text="&#x23F1;" FontSize="28" Margin="0,0,0,8"/>
                    <TextBlock Text="Runtime trace" Foreground="{StaticResource Text}"
                               FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Foreground="{StaticResource Subtext}" FontSize="11" TextWrapping="Wrap"
                               Margin="0,4,0,0"
                               Text="Live ETW monitoring. Opens the Runtime Trace page; promote phantoms from there to continue the wizard via Scan."/>
                </StackPanel>
            </RadioButton>
        </Grid>

        <!-- Path input (hidden for Runtime) -->
        <Grid Grid.Row="3" x:Name="PathRow" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="PathBox" Grid.Column="0"
                     FontFamily="{StaticResource FontMono}" FontSize="12"
                     TextChanged="PathBox_Changed"/>
            <Button Grid.Column="1" x:Name="BrowseFileBtn" Content="Browse file..."
                    Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="BrowseFile_Click"/>
            <Button Grid.Column="2" x:Name="BrowseDirBtn" Content="Browse folder..."
                    Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="BrowseDir_Click"/>
        </Grid>

        <!-- Runtime hint (visible only when Runtime selected) -->
        <Border Grid.Row="3" x:Name="RuntimeHint" Visibility="Collapsed"
                Background="#1F00F0A3" BorderBrush="{StaticResource Phosphor}" BorderThickness="0,0,0,1"
                CornerRadius="6" Padding="14,10" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="RUNTIME TRACE" Foreground="{StaticResource Phosphor}"
                           FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Bold"/>
                <TextBlock Foreground="{StaticResource Text}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"
                           Text="Runtime trace lives outside the wizard. Press Continue to jump to the Runtime Trace page. There, launch or attach to your target, then use 'Promote to Scan' to bring the discovered phantoms back into the wizard via the Scan a folder entry."/>
            </StackPanel>
        </Border>

        <!-- Detection badge (only when path-based entries) -->
        <Border Grid.Row="4" x:Name="DetectBox" Background="{StaticResource Surface0}"
                BorderBrush="{StaticResource Ring}" BorderThickness="1" CornerRadius="6"
                Padding="14,10" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="DetectIcon" Text="&#x1F4C1;" FontSize="16" VerticalAlignment="Center"/>
                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="DetectKind" Text="No input yet" FontSize="12" FontWeight="SemiBold"
                               FontFamily="{StaticResource FontMono}" Foreground="{StaticResource Overlay}"/>
                    <TextBlock x:Name="DetectHint" FontSize="11" Foreground="{StaticResource Subtext}"
                               Margin="0,2,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Hunting-for selector -->
        <TextBlock Grid.Row="5" Text="HUNTING FOR" Foreground="{StaticResource Blue}"
                   FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Bold"
                   Margin="0,8,0,6"/>
        <StackPanel Grid.Row="6" Orientation="Horizontal">
            <Border Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                    BorderThickness="1" CornerRadius="6" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="GoalCode" GroupName="Goal"
                                 Style="{StaticResource SegmentedRadio}" IsChecked="True"
                                 Content="Arbitrary code (default)"/>
                    <RadioButton x:Name="GoalPrivesc" GroupName="Goal"
                                 Style="{StaticResource SegmentedRadio}"
                                 Content="Local privesc (SYSTEM)"/>
                    <RadioButton x:Name="GoalPersist" GroupName="Goal"
                                 Style="{StaticResource SegmentedRadio}"
                                 Content="Persistence"/>
                </StackPanel>
            </Border>
            <TextBlock x:Name="GoalHint" Margin="14,0,0,0" VerticalAlignment="Center"
                       FontSize="11" Foreground="{StaticResource Overlay}"
                       TextWrapping="Wrap" MaxWidth="380"
                       Text="Code execution in the user's context — the common case. Survey ranks by exploitability + writable ACLs."/>
        </StackPanel>
    </Grid>
</UserControl>
