<UserControl x:Class="DllSidecar.GUI.Views.Wizard.Stages.ReportStage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="24,20">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Step 6 · Report"
                       FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,0,4"/>
            <TextBlock FontSize="12" Foreground="{StaticResource Subtext}" TextWrapping="Wrap">
                <Run Text="• First draft auto-filled from session state"/><LineBreak/>
                <Run Text="• Edit inline · export as .md or PDF"/>
            </TextBlock>
        </StackPanel>

        <Border DockPanel.Dock="Bottom" Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Copy markdown" Style="{StaticResource SecondaryButton}" Click="Copy_Click"/>
                <Button Content="Save .md" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="SaveMd_Click"/>
                <Button Content="Export PDF" Style="{StaticResource TerminalButton}" Margin="8,0,0,0" Click="ExportPdf_Click"/>
            </StackPanel>
        </Border>

        <Border Background="{StaticResource Base}" BorderBrush="{StaticResource Ring}"
                BorderThickness="1" CornerRadius="8">
            <TextBox x:Name="MdView" Background="Transparent" Foreground="{StaticResource Text}"
                     BorderThickness="0" Padding="14,10" IsReadOnly="False"
                     FontFamily="{StaticResource FontMono}" FontSize="11"
                     TextWrapping="NoWrap" AcceptsReturn="True" AcceptsTab="True"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     SpellCheck.IsEnabled="False"/>
        </Border>
    </DockPanel>
</UserControl>
