<UserControl x:Class="DllSidecar.GUI.Views.Wizard.Stages.PickStage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:DllSidecar.Core.Models;assembly=DllSidecar.Core">
    <DockPanel Margin="24,20">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
            <TextBlock Text="Step 4 · Pick the target"
                       FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,0,4"/>
            <TextBlock FontSize="12" Foreground="{StaticResource Subtext}" Margin="0,0,0,0" TextWrapping="Wrap">
                <Run Text="• Ranked by Total (Exploit×0.5 + Impact×0.3 + Conf×0.2) · click a header to sort by a single axis"/><LineBreak/>
                <Run Text="• EXISTING → generate Proxy · PHANTOM → generate Sideload"/>
            </TextBlock>
        </StackPanel>

        <Border DockPanel.Dock="Top" Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                BorderThickness="1" CornerRadius="4" Margin="0,0,0,6" Padding="8,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="SEARCH" Foreground="{StaticResource Blue}"
                           FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Column="1" x:Name="SearchBox"
                         Background="Transparent" BorderThickness="0"
                         FontFamily="{StaticResource FontMono}" FontSize="11" Padding="0,2"
                         ToolTip="Filter rows by DLL name, path, kind (EXISTING / IAT / RUNTIME), or privesc label"
                         TextChanged="SearchBox_Changed"/>
                <Button Grid.Column="2" x:Name="CopyListBtn" Content="&#x29C9;"
                        Style="{StaticResource IconButton}" Margin="6,0,0,0"
                        Click="CopyList_Click"
                        ToolTip="Copy current filtered candidate list to clipboard (TSV)"/>
                <Button Grid.Column="3" x:Name="ExportCsvBtn" Content="&#x21A7;"
                        Style="{StaticResource IconButton}" Margin="6,0,0,0"
                        Click="ExportCsv_Click"
                        ToolTip="Export current filtered candidate list to CSV/TSV"/>
            </Grid>
        </Border>

        <Border Background="{StaticResource Base}" BorderBrush="{StaticResource Ring}"
                BorderThickness="1" CornerRadius="8" Padding="2">
            <DataGrid x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                      Background="Transparent" Foreground="{StaticResource Text}" BorderThickness="0"
                      RowBackground="{StaticResource Mantle}" AlternatingRowBackground="{StaticResource Surface0}"
                      GridLinesVisibility="None" HeadersVisibility="Column"
                      FontFamily="{StaticResource FontMono}" FontSize="11"
                      SelectionMode="Single" RowHeight="30"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{StaticResource Surface1}"/>
                        <Setter Property="Foreground" Value="{StaticResource Subtext}"/>
                        <Setter Property="Padding" Value="10,7"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Resources>
                    <Style x:Key="ExploitCell" TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{StaticResource Phosphor}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                    <Style x:Key="ImpactCell" TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{StaticResource Red}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                    <Style x:Key="ConfCell" TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{StaticResource Blue}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Total"   Binding="{Binding ScoreText}"      Width="55" SortMemberPath="ScoreValue"/>
                    <DataGridTextColumn Header="Exploit" Binding="{Binding ExploitText}"    Width="60" SortMemberPath="ExploitValue" ElementStyle="{StaticResource ExploitCell}"/>
                    <DataGridTextColumn Header="Impact"  Binding="{Binding ImpactText}"     Width="55" SortMemberPath="ImpactValue"  ElementStyle="{StaticResource ImpactCell}"/>
                    <DataGridTextColumn Header="Conf"    Binding="{Binding ConfidenceText}" Width="50" SortMemberPath="ConfidenceValue" ElementStyle="{StaticResource ConfCell}"/>
                    <DataGridTextColumn Header="Kind"    Binding="{Binding Kind}"           Width="80"/>
                    <DataGridTextColumn Header="DLL"     Binding="{Binding Filename}"       Width="180"/>
                    <DataGridTextColumn Header="Privesc" Binding="{Binding Privesc}"        Width="80"/>
                    <DataGridTextColumn Binding="{Binding AccessLabel}" Width="200"
                                        SortMemberPath="AccessLabel">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="Access">
                                <TextBlock.ToolTip>
                                    <ToolTip MaxWidth="500">
                                        <TextBlock TextWrapping="Wrap">
                                            <Run FontWeight="Bold" Text="Access column"/>
                                            <LineBreak/>
                                            <Run Text="Mirrors ProcMon's "/><Run FontFamily="Consolas" Text="Options:"/><Run Text=" field. Same vocabulary as the ProcMon and Runtime trace pages. NT constants below come from "/><Run FontFamily="Consolas" Text="wdm.h"/><Run Text=" (Windows Internals, Russinovich)."/>
                                            <LineBreak/><LineBreak/>
                                            <Run FontWeight="Bold" Text="{x:Static models:AccessClassLabels.Load}"/>
                                            <Run Text=" — also "/><Run FontFamily="Consolas" Text="FILE_SYNCHRONOUS_IO_NONALERT (0x20)"/><Run Text=". Loader image-map open: a planted file at this path WOULD be executed. Counts as 'dynamically verified'."/>
                                            <LineBreak/><LineBreak/>
                                            <Run FontWeight="Bold" Text="{x:Static models:AccessClassLabels.Probe}"/>
                                            <Run Text=" — value 0x200000. Metadata-only probe (GetFileAttributes / PathFileExists / FindFirstFile class). A planted DLL here would NOT execute. Does NOT count as verified — Confidence stays at the static floor."/>
                                            <LineBreak/><LineBreak/>
                                            <Run FontWeight="Bold" Text="Mixed"/>
                                            <Run Text=" — at least one real load alongside probe events."/>
                                            <LineBreak/><LineBreak/>
                                            <Run FontWeight="Bold" Text="(empty)"/>
                                            <Run Text=" — no runtime evidence attached yet, or events could not be classified."/>
                                        </TextBlock>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </DataGridTextColumn.Header>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="ToolTip" Value="{Binding AccessTooltip}"/>
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="{x:Static models:AccessClassLabels.Load}">
                                        <Setter Property="Foreground" Value="{StaticResource Phosphor}"/>
                                    </Trigger>
                                    <Trigger Property="Text" Value="{x:Static models:AccessClassLabels.Probe}">
                                        <Setter Property="Foreground" Value="{StaticResource Yellow}"/>
                                    </Trigger>
                                    <Trigger Property="Text" Value="{x:Static models:AccessClassLabels.Mixed}">
                                        <Setter Property="Foreground" Value="{StaticResource Blue}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding DirBadge}" Width="80">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="Dir" ToolTip="OPEN = any low-priv user can drop · USER = only the current user can write (e.g. %APPDATA%) · LOCKED = admin required (Program Files, System32) · ? = ACL check failed"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Path"    Binding="{Binding ShortPath}"      Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</UserControl>
