<UserControl x:Class="DllSidecar.GUI.Views.Wizard.Stages.SurveyStage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Grid with * row for DataGrid so it fills all available vertical space
         instead of being capped at MaxHeight=640 inside a ScrollViewer. -->
    <Grid Margin="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Step 2 · Survey"
                   FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,0,4"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock FontSize="12" Foreground="{StaticResource Overlay}" Margin="0,0,0,4"
                       Text="Auto-runs on entry."/>
            <TextBlock FontSize="12" Foreground="{StaticResource Subtext}" TextWrapping="Wrap">
                <Run Text="• Extract installer (if needed)"/><LineBreak/>
                <Run Text="• Static scan: IAT cross-ref · Authenticode · directory ACL"/><LineBreak/>
                <Run Text="• Privesc vectors: services · tasks · autoElevate · updater heuristic"/>
            </TextBlock>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource Surface0}" BorderBrush="{StaticResource Ring}"
                    BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="EXISTING" FontFamily="{StaticResource FontMono}" FontSize="10"
                               FontWeight="Medium" Foreground="{StaticResource Overlay}"/>
                    <TextBlock x:Name="StExisting" Text="—" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource Green}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="{StaticResource Surface0}" BorderBrush="{StaticResource Ring}"
                    BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="3,0">
                <StackPanel>
                    <TextBlock Text="PHANTOMS" FontFamily="{StaticResource FontMono}" FontSize="10"
                               FontWeight="Medium" Foreground="{StaticResource Overlay}"/>
                    <TextBlock x:Name="StPhantoms" Text="—" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource Mauve}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="{StaticResource Surface0}" BorderBrush="{StaticResource Ring}"
                    BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="3,0">
                <StackPanel>
                    <TextBlock Text="TOP SCORE" FontFamily="{StaticResource FontMono}" FontSize="10"
                               FontWeight="Medium" Foreground="{StaticResource Overlay}"/>
                    <TextBlock x:Name="StTop" Text="—" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource Red}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Background="{StaticResource Surface0}" BorderBrush="{StaticResource Ring}"
                    BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="6,0,0,0">
                <StackPanel>
                    <TextBlock Text="PRIVESC" FontFamily="{StaticResource FontMono}" FontSize="10"
                               FontWeight="Medium" Foreground="{StaticResource Overlay}"/>
                    <TextBlock x:Name="StPrivesc" Text="—" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource Phosphor}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3"
                   Text="CANDIDATES (ranked by Total · E×0.5 + I×0.3 + C×0.2 — click a column header to re-sort)"
                   FontFamily="{StaticResource FontMono}"
                   FontSize="10" FontWeight="Medium" Foreground="{StaticResource Blue}" Margin="0,4,0,8"/>

        <!-- Candidates grid stretches to fill the remaining height -->
        <Border Grid.Row="4" Background="{StaticResource Surface0}" BorderBrush="{StaticResource Ring}"
                BorderThickness="1" CornerRadius="8" MinHeight="300">
            <DataGrid x:Name="CandidatesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      Background="Transparent" Foreground="{StaticResource Text}" BorderThickness="0"
                      RowBackground="Transparent" AlternatingRowBackground="Transparent"
                      GridLinesVisibility="None" HeadersVisibility="Column"
                      FontFamily="Cascadia Mono,Consolas" FontSize="11"
                      RowHeight="26" VerticalScrollBarVisibility="Auto"
                      SelectionMode="Single">
                <DataGrid.Resources>
                    <!-- Override row template so we can light up the TOP-rank rows
                         with a phosphor bar, independent of selection. -->
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="SnapsToDevicePixels" Value="True"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridRow">
                                    <Border x:Name="RowBd"
                                            BorderBrush="Transparent" BorderThickness="3,0,0,0"
                                            Background="{TemplateBinding Background}">
                                        <SelectiveScrollingGrid>
                                            <SelectiveScrollingGrid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </SelectiveScrollingGrid.ColumnDefinitions>
                                            <DataGridCellsPresenter Grid.Column="1"
                                                ItemsPanel="{TemplateBinding ItemsPanel}"/>
                                            <DataGridRowHeader
                                                Visibility="{Binding HeadersVisibility, ConverterParameter={x:Static DataGridHeadersVisibility.Row}, Converter={x:Static DataGrid.HeadersVisibilityConverter}, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                        </SelectiveScrollingGrid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsTop}" Value="True">
                                            <Setter TargetName="RowBd" Property="BorderBrush" Value="{StaticResource Phosphor}"/>
                                            <Setter TargetName="RowBd" Property="Background" Value="#1F00F0A3"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="RowBd" Property="BorderBrush" Value="#4D00F0A3"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="RowBd" Property="Background" Value="#243027"/>
                                            <Setter TargetName="RowBd" Property="BorderBrush" Value="{StaticResource Phosphor}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{StaticResource Surface1}"/>
                        <Setter Property="Foreground" Value="{StaticResource Subtext}"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Total"   Binding="{Binding ScoreText}"      Width="55" SortMemberPath="ScoreValue"/>
                    <DataGridTextColumn Header="Exploit" Binding="{Binding ExploitText}"    Width="60" SortMemberPath="ExploitValue">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource Phosphor}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Impact"  Binding="{Binding ImpactText}"     Width="55" SortMemberPath="ImpactValue">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource Red}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Conf"    Binding="{Binding ConfidenceText}" Width="50" SortMemberPath="ConfidenceValue">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource Blue}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Kind"    Binding="{Binding Kind}"           Width="80"/>
                    <DataGridTextColumn Header="DLL"     Binding="{Binding Filename}"       Width="170"/>
                    <DataGridTextColumn Header="Privesc" Binding="{Binding Privesc}"        Width="80"/>
                    <DataGridTextColumn Binding="{Binding DirBadge}" Width="80">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="Dir" ToolTip="OPEN = any low-priv user can drop · USER = only the current user can write (e.g. %APPDATA%) · LOCKED = admin required (Program Files, System32) · ? = ACL check failed"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Path"    Binding="{Binding ShortPath}"      Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock Grid.Row="5" x:Name="StatusLine" Foreground="{StaticResource Overlay}" FontSize="11"
                   FontFamily="Cascadia Mono,Consolas" Margin="0,12,0,0" TextWrapping="Wrap"/>
    </Grid>
</UserControl>
