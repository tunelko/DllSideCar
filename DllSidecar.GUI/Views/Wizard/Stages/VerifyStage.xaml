<UserControl x:Class="DllSidecar.GUI.Views.Wizard.Stages.VerifyStage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20">
            <TextBlock Text="Step 3 · Verify (optional)"
                       FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,0,4"/>
            <TextBlock FontSize="12" Foreground="{StaticResource Subtext}" Margin="0,0,0,18" TextWrapping="Wrap">
                <Run Text="• Match with ProcMon CSV — dynamic ground truth vs. static scan"/><LineBreak/>
                <Run Text="• Runs only if you point it to a CSV — skip to stay purely static"/><LineBreak/>
                <Run Foreground="#737373" Text="NVD dedup runs automatically in the Report stage using the picked target."/>
            </TextBlock>

            <!-- ProcMon row -->
            <Border Background="{StaticResource Surface0}" BorderBrush="{StaticResource Ring}"
                    BorderThickness="1" CornerRadius="8" Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PROCMON CSV" FontFamily="{StaticResource FontMono}" FontSize="10"
                                   FontWeight="Medium" Foreground="{StaticResource Blue}"/>
                        <TextBlock x:Name="ProcmonLine" Foreground="{StaticResource Text}" FontSize="13"
                                   Margin="0,4,0,0" Text="No CSV loaded."/>
                    </StackPanel>
                    <Button Grid.Column="1" x:Name="LoadProcmonBtn" Content="Load CSV..."
                            Style="{StaticResource SecondaryButton}" VerticalAlignment="Center"
                            Click="LoadProcmon_Click"/>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
