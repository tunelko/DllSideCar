<Window x:Class="DllSidecar.GUI.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="About DllSidecar"
        Width="640" Height="720"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource Base}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32" ResizeBorderThickness="0"
                            GlassFrameThickness="0" CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>      <!-- 0: title strip (Crust band) -->
            <RowDefinition Height="*"/>       <!-- 1: logo -->
            <RowDefinition Height="Auto"/>    <!-- 2: info -->
            <RowDefinition Height="Auto"/>    <!-- 3: actions -->
        </Grid.RowDefinitions>

        <!-- Title strip matching MainWindow chrome -->
        <Border Grid.Row="0" Background="{StaticResource Crust}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource HudWindowCloseButton}"
                        Click="Close_Click" ToolTip="Close (Esc)"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="&#x2715;" FontSize="14"/>
                </Button>
                <TextBlock Text="About DllSidecar"
                           VerticalAlignment="Center" Margin="14,0,0,0"
                           Foreground="{StaticResource Overlay}" FontSize="11"
                           FontFamily="{StaticResource FontMono}"/>
            </DockPanel>
        </Border>

        <!-- Logo; PNG alpha blends into the dark background. -->
        <Image Grid.Row="1" Source="pack://application:,,,/Assets/dllsidecar.png"
               Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
               Margin="20,24,20,8" MaxHeight="380"/>

        <!-- Info -->
        <StackPanel Grid.Row="2" Margin="28,4,28,8">
            <TextBlock Text="DllSidecar" FontSize="22" FontWeight="SemiBold"
                       Foreground="{StaticResource Text}" HorizontalAlignment="Center"/>
            <TextBlock Text="DLL Sideloading research toolkit"
                       FontSize="12" Foreground="{StaticResource Subtext}"
                       HorizontalAlignment="Center" Margin="0,2,0,14"/>

            <Grid HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Version" FontFamily="{StaticResource FontMono}"
                           FontSize="11" Foreground="{StaticResource Overlay}" Margin="0,0,18,5"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="VersionText" FontFamily="{StaticResource FontMono}"
                           FontSize="11" Foreground="{StaticResource Text}" Margin="0,0,0,5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" x:Name="AuthorLabel" Text="Researcher"
                           FontFamily="{StaticResource FontMono}"
                           FontSize="11" Foreground="{StaticResource Overlay}" Margin="0,0,18,5"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="AuthorText"
                           FontFamily="{StaticResource FontMono}" FontSize="11"
                           Foreground="{StaticResource Text}" Margin="0,0,0,5"/>

                <TextBlock Grid.Row="2" Grid.Column="0" x:Name="BlogLabel" Text="Blog"
                           FontFamily="{StaticResource FontMono}"
                           FontSize="11" Foreground="{StaticResource Overlay}" Margin="0,0,18,5"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="BlogContainer" Margin="0,0,0,5"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Repo" FontFamily="{StaticResource FontMono}"
                           FontSize="11" Foreground="{StaticResource Overlay}" Margin="0,0,18,5"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,5">
                    <Hyperlink NavigateUri="https://github.com/tunelko/DllSideCar" RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="{StaticResource Mauve}">
                        <Run Text="github.com/tunelko/DllSideCar" FontFamily="{StaticResource FontMono}" FontSize="11"/>
                    </Hyperlink>
                </TextBlock>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="License" FontFamily="{StaticResource FontMono}"
                           FontSize="11" Foreground="{StaticResource Overlay}" Margin="0,0,18,5"/>
                <TextBlock Grid.Row="4" Grid.Column="1" Text="Research / personal use"
                           FontFamily="{StaticResource FontMono}" FontSize="11"
                           Foreground="{StaticResource Text}" Margin="0,0,0,5"/>
            </Grid>

            <TextBlock Text="Independent security research — DLL sideloading / hijacking (CWE-427 / CWE-426)"
                       HorizontalAlignment="Center" FontSize="10"
                       Foreground="{StaticResource Overlay}" Margin="0,16,0,0"/>
        </StackPanel>

        <!-- Actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="18,8,18,18">
            <Button Content="Close" Style="{StaticResource SecondaryButton}" IsCancel="True" IsDefault="True"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
