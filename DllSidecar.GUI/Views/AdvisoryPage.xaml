<Page x:Class="DllSidecar.GUI.Views.AdvisoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ctrl="clr-namespace:DllSidecar.GUI.Controls"
      Background="{StaticResource Base}">
    <Grid>
    <Grid Margin="28,20,28,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Advisory Generator" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource Text}"/>
            <TextBlock FontSize="12" Foreground="{StaticResource Overlay}" Margin="0,4,0,0" TextWrapping="Wrap"
                       Text="Render a Markdown advisory from the current analysis context (target PE, privesc findings, CVE dedup if run). Edit freely in the left pane — the right pane shows a live preview. Export to .md file, print to PDF, or copy to clipboard."/>
        </StackPanel>

        <!-- Context summary: vendor editable inline so mis-detected values can be fixed per-record -->
        <Border Grid.Row="1" Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="CONTEXT" FontFamily="{StaticResource FontMono}" FontSize="10"
                               FontWeight="Medium" Foreground="{StaticResource Blue}"/>
                    <TextBlock x:Name="ContextLine" Foreground="{StaticResource Text}" FontSize="12"
                               Margin="0,4,0,0" TextWrapping="Wrap"/>
                    <TextBlock x:Name="ContextHint" Foreground="{StaticResource Overlay}" FontSize="10"
                               Margin="0,3,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,10,0">
                    <TextBlock Text="Vendor" Foreground="{StaticResource Subtext}" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="VendorBox" Width="200" Padding="6,4" FontSize="11"
                             TextChanged="VendorBox_Changed"
                             ToolTip="Override the autodetected vendor. Takes effect immediately on Save to Library."/>
                </StackPanel>
                <Button Grid.Column="2" Content="Reload context" Style="{StaticResource SecondaryButton}"
                        VerticalAlignment="Center" Click="ReloadContext_Click"
                        ToolTip="Re-read CurrentAnalysis and regenerate the markdown from template"/>
            </Grid>
        </Border>

        <!-- CVSS quick controls — 8 base metrics + live score -->
        <Border Grid.Row="2" Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="CVSS 3.1" FontFamily="{StaticResource FontMono}" FontSize="10"
                           FontWeight="Medium" Foreground="{StaticResource Blue}"
                           VerticalAlignment="Center" Margin="0,0,14,0"/>

                <TextBlock Text="AV" VerticalAlignment="Center" Foreground="{StaticResource Subtext}" FontSize="11" Margin="0,0,4,0"/>
                <ComboBox x:Name="CvssAv" Width="62" SelectionChanged="Cvss_Changed" Margin="0,0,8,0"/>
                <TextBlock Text="AC" VerticalAlignment="Center" Foreground="{StaticResource Subtext}" FontSize="11" Margin="0,0,4,0"/>
                <ComboBox x:Name="CvssAc" Width="62" SelectionChanged="Cvss_Changed" Margin="0,0,8,0"/>
                <TextBlock Text="PR" VerticalAlignment="Center" Foreground="{StaticResource Subtext}" FontSize="11" Margin="0,0,4,0"/>
                <ComboBox x:Name="CvssPr" Width="62" SelectionChanged="Cvss_Changed" Margin="0,0,8,0"/>
                <TextBlock Text="UI" VerticalAlignment="Center" Foreground="{StaticResource Subtext}" FontSize="11" Margin="0,0,4,0"/>
                <ComboBox x:Name="CvssUi" Width="62" SelectionChanged="Cvss_Changed" Margin="0,0,8,0"/>
                <TextBlock Text="S"  VerticalAlignment="Center" Foreground="{StaticResource Subtext}" FontSize="11" Margin="0,0,4,0"/>
                <ComboBox x:Name="CvssS"  Width="62" SelectionChanged="Cvss_Changed" Margin="0,0,8,0"/>
                <TextBlock Text="C"  VerticalAlignment="Center" Foreground="{StaticResource Subtext}" FontSize="11" Margin="0,0,4,0"/>
                <ComboBox x:Name="CvssC"  Width="62" SelectionChanged="Cvss_Changed" Margin="0,0,8,0"/>
                <TextBlock Text="I"  VerticalAlignment="Center" Foreground="{StaticResource Subtext}" FontSize="11" Margin="0,0,4,0"/>
                <ComboBox x:Name="CvssI"  Width="62" SelectionChanged="Cvss_Changed" Margin="0,0,8,0"/>
                <TextBlock Text="A"  VerticalAlignment="Center" Foreground="{StaticResource Subtext}" FontSize="11" Margin="0,0,4,0"/>
                <ComboBox x:Name="CvssA"  Width="62" SelectionChanged="Cvss_Changed" Margin="0,0,14,0"/>

                <TextBlock x:Name="CvssResult" VerticalAlignment="Center"
                           FontFamily="{StaticResource FontMono}" FontSize="12" FontWeight="Bold"
                           Foreground="{StaticResource Yellow}" Text="Score: —" Margin="0,0,14,0"/>
                <Button Content="Apply to markdown" Style="{StaticResource SecondaryButton}"
                        VerticalAlignment="Center" Click="ApplyCvss_Click"/>
            </StackPanel>
        </Border>

        <!-- Single pane with Edit/Preview toggle -->
        <Border Grid.Row="3" Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                BorderThickness="1" CornerRadius="6">
            <DockPanel>
                <!-- Top toolbar: template selector + edit/preview toggle -->
                <Grid DockPanel.Dock="Top" Background="{StaticResource Surface0}" Height="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="TEMPLATE" VerticalAlignment="Center"
                               Margin="14,0,8,0"
                               FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                               Foreground="{StaticResource Blue}"/>
                    <ComboBox Grid.Column="1" x:Name="TemplateCombo" Width="210" Height="24"
                              VerticalAlignment="Center"
                              SelectionChanged="TemplateCombo_Changed"
                              ToolTip="Destination format. Switching re-renders the editor. Save creates a file in the matching format folder of the Library tree."/>
                    <Button x:Name="FormFieldsBtn" Grid.Column="2" Content="Template fields…"
                            Style="{StaticResource SecondaryButton}" Margin="10,4,0,4"
                            VerticalAlignment="Center" Padding="10,0"
                            Click="OpenFormFields_Click"
                            ToolTip="Edit the extra fields this template consumes (attack type, vendor POC, proposed solution, CVSS v4, …) in a dedicated modal."/>
                    <TextBlock Grid.Column="3" x:Name="ModeLabel" Text=""
                               Margin="14,0,0,0" VerticalAlignment="Center"
                               FontFamily="{StaticResource FontMono}" FontSize="10"
                               Foreground="{StaticResource Overlay}"/>
                    <!-- Segmented toggle: Edit / Preview -->
                    <Border Grid.Column="4" Margin="0,4,6,4" Background="{StaticResource Mantle}"
                            BorderBrush="{StaticResource Ring}" BorderThickness="1" CornerRadius="6">
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton x:Name="EditModeBtn" Content="Edit" IsChecked="True"
                                          Style="{StaticResource SegmentedToggle}"
                                          Checked="EditMode_Checked"/>
                            <ToggleButton x:Name="PreviewModeBtn" Content="Preview"
                                          Style="{StaticResource SegmentedToggle}"
                                          Checked="PreviewMode_Checked"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid>
                    <!-- Editor -->
                    <TextBox x:Name="MdEditor" Background="Transparent" Foreground="{StaticResource Text}"
                             BorderThickness="0" Padding="16,12"
                             FontFamily="{StaticResource FontMono}" FontSize="12"
                             TextWrapping="NoWrap" AcceptsReturn="True" AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             TextChanged="MdEditor_TextChanged"
                             SpellCheck.IsEnabled="False"/>
                    <!-- Preview (hidden by default) -->
                    <WebBrowser x:Name="Preview" Visibility="Collapsed"/>
                </Grid>
            </DockPanel>
        </Border>

        <!-- Footer actions -->
        <Border Grid.Row="4" Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="FooterStatus" VerticalAlignment="Center"
                           FontFamily="{StaticResource FontMono}" FontSize="11"
                           Foreground="{StaticResource Overlay}" TextTrimming="CharacterEllipsis"
                           Text="Ready — analyze a PE first, or the template will fall back to placeholders."/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="SaveToLibraryBtn" Content="Save to Library" Style="{StaticResource TerminalButton}"
                            Click="SaveToLibrary_Click"
                            ToolTip="Persist this advisory into the local library (SQLite). Label flips to 'Update record' when an existing record is loaded."/>
                    <Button Content="Copy all" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="CopyAll_Click"/>
                    <Button x:Name="SaveSourceBtn" Content="Save .md" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="SaveMd_Click"/>
                    <Button x:Name="SaveHtmlBtn" Content="Save HTML" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="SaveHtml_Click"
                            ToolTip="Save a styled HTML file (Markdown only)"/>
                    <Button Content="&#x21A7;  Export PDF" Style="{StaticResource AccentButton}" Margin="8,0,0,0" Click="ExportPdf_Click"
                            ToolTip="Render directly to PDF — no print dialog, no external tool needed"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
    <ctrl:LoadingOverlay x:Name="Overlay"/>
    </Grid>
</Page>
