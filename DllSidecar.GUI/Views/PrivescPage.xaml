<Page x:Class="DllSidecar.GUI.Views.PrivescPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ctrl="clr-namespace:DllSidecar.GUI.Controls"
      Background="{StaticResource Base}">
    <Page.Resources>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Mantle}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Ring}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>
    </Page.Resources>
    <Grid>
    <Grid Margin="28,20,28,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Privesc Surface" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource Text}"/>
            <TextBlock Foreground="{StaticResource Overlay}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"
                       Text="Map the privilege escalation surface of a target directory. Four modular detectors run independently: services that execute as LocalSystem, scheduled tasks with HighestAvailable principal, EXE manifests with autoElevate=true, and updater/maintenance heuristics. Critical severity marks the classic user→SYSTEM chain."/>

        </StackPanel>

        <!-- Path picker -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="DirPathBox" Grid.Column="0" FontFamily="{StaticResource FontMono}"/>
            <Button Grid.Column="1" x:Name="BrowseBtn" Content="&#x1F4C1;"
                    Style="{StaticResource IconButton}" Margin="10,0,0,0" Click="Browse_Click"
                    ToolTip="Browse for directory"/>
            <Button Grid.Column="2" x:Name="AnalyzeBtn" Content="ANALYZE"
                    Style="{StaticResource TerminalButton}" Margin="10,0,0,0" Click="Analyze_Click"/>
            <Button Grid.Column="3" x:Name="CancelBtn" Content="Cancel"
                    Style="{StaticResource DangerButton}" Margin="10,0,0,0"
                    Click="Cancel_Click" IsEnabled="False" Visibility="Collapsed"/>
        </Grid>

        <!-- Vectors -->
        <Border Grid.Row="2" Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="VECTORS" Foreground="{StaticResource Blue}"
                           FontWeight="Bold" FontSize="11" FontFamily="{StaticResource FontMono}"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Border Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                        BorderThickness="1" CornerRadius="6">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="ChkServices" Style="{StaticResource SegmentedCheck}"
                                  Content="Services" IsChecked="True"/>
                        <CheckBox x:Name="ChkTasks" Style="{StaticResource SegmentedCheck}"
                                  Content="Scheduled tasks" IsChecked="True"/>
                        <CheckBox x:Name="ChkAutoElevate" Style="{StaticResource SegmentedCheck}"
                                  Content="AutoElevate" IsChecked="True"/>
                        <CheckBox x:Name="ChkUpdater" Style="{StaticResource SegmentedCheck}"
                                  Content="Updater heuristic" IsChecked="True"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Stats -->
        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="PE ANALYZED" FontSize="10" FontWeight="Medium"
                               FontFamily="{StaticResource FontMono}" Foreground="{StaticResource Overlay}"/>
                    <TextBlock x:Name="StatPEs" Text="0" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource Text}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="3,0">
                <StackPanel>
                    <TextBlock Text="SYSTEM" FontSize="10" FontWeight="Medium"
                               FontFamily="{StaticResource FontMono}" Foreground="{StaticResource Overlay}"/>
                    <TextBlock x:Name="StatSystem" Text="0" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource Red}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="3,0">
                <StackPanel>
                    <TextBlock Text="TASKS" FontSize="10" FontWeight="Medium"
                               FontFamily="{StaticResource FontMono}" Foreground="{StaticResource Overlay}"/>
                    <TextBlock x:Name="StatTasks" Text="0" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource Yellow}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource StatCard}" Margin="3,0">
                <StackPanel>
                    <TextBlock Text="AUTO-ELEVATE" FontSize="10" FontWeight="Medium"
                               FontFamily="{StaticResource FontMono}" Foreground="{StaticResource Overlay}"/>
                    <TextBlock x:Name="StatAuto" Text="0" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource Mauve}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Style="{StaticResource StatCard}" Margin="6,0,0,0">
                <StackPanel>
                    <TextBlock Text="JACKPOT" FontSize="10" FontWeight="Medium"
                               FontFamily="{StaticResource FontMono}" Foreground="{StaticResource Overlay}"/>
                    <TextBlock x:Name="StatJackpot" Text="0" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource Phosphor}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Results -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource Mantle}"
                    BorderBrush="{StaticResource Ring}" BorderThickness="1"
                    CornerRadius="6" Padding="2" Margin="0,0,6,0">
                <DataGrid x:Name="FindingsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          Background="Transparent" Foreground="{StaticResource Text}" BorderThickness="0"
                          RowBackground="{StaticResource Surface0}" AlternatingRowBackground="#1F1F1F"
                          GridLinesVisibility="None" HeadersVisibility="Column"
                          FontFamily="{StaticResource FontMono}" FontSize="11"
                          SelectionMode="Single" RowHeight="28"
                          SelectionChanged="FindingsGrid_SelectionChanged"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{StaticResource Surface1}"/>
                            <Setter Property="Foreground" Value="{StaticResource Subtext}"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Severity" Width="85" SortMemberPath="SeverityOrder">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding SeverityBg}" CornerRadius="999"
                                            Padding="8,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SeverityLabel}" Foreground="{Binding SeverityFg}"
                                                   FontSize="10" FontWeight="Bold"
                                                   FontFamily="{StaticResource FontBadge}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Vector" Binding="{Binding VectorLabel}" Width="100"/>
                        <DataGridTextColumn Header="PE" Binding="{Binding PeFilename}" Width="180"/>
                        <DataGridTextColumn Header="Account" Binding="{Binding Account}" Width="140"/>
                        <DataGridTextColumn Header="Detail" Binding="{Binding Title}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Details -->
            <Border Grid.Column="1" Background="{StaticResource Mantle}"
                    BorderBrush="{StaticResource Ring}" BorderThickness="1"
                    CornerRadius="6" Padding="18,14" Margin="6,0,0,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="FINDING DETAILS" FontFamily="{StaticResource FontMono}"
                                   FontSize="11" FontWeight="Medium" Foreground="{StaticResource Phosphor}"
                                   Margin="0,0,0,8"/>
                        <Button x:Name="OpenAnalyzeBtn" Content="Open PE in Analyze" Style="{StaticResource AccentButton}"
                                HorizontalAlignment="Left" Margin="0,0,0,8" Visibility="Collapsed"
                                Click="OpenInAnalyze_Click"/>
                    </StackPanel>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="DetailEmpty"
                                   Text="Select a row to see full finding evidence + runner path + source PE."
                                   Foreground="{StaticResource Overlay}" FontSize="11" TextWrapping="Wrap"/>
                        <StackPanel x:Name="DetailContent" Visibility="Collapsed">
                            <TextBlock x:Name="DetailTitle" Foreground="{StaticResource Text}" FontSize="14"
                                       FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <TextBlock x:Name="DetailPe" Foreground="{StaticResource Subtext}"
                                       FontFamily="{StaticResource FontMono}" FontSize="10"
                                       TextWrapping="Wrap" Margin="0,0,0,14"/>

                            <TextBlock Text="EVIDENCE" Foreground="{StaticResource Blue}" FontWeight="Bold"
                                       FontSize="10" FontFamily="{StaticResource FontMono}" Margin="0,4,0,4"/>
                            <TextBlock x:Name="DetailEvidence" Foreground="{StaticResource Text}" FontSize="11"
                                       FontFamily="{StaticResource FontMono}" TextWrapping="Wrap"/>

                            <TextBlock Text="PRIVILEGED CONTEXT" Foreground="{StaticResource Blue}" FontWeight="Bold"
                                       FontSize="10" FontFamily="{StaticResource FontMono}" Margin="0,14,0,4"/>
                            <TextBlock x:Name="DetailContext" Foreground="{StaticResource Text}" FontSize="11"
                                       FontFamily="{StaticResource FontMono}" TextWrapping="Wrap"/>

                            <TextBlock Text="EXTRAS" Foreground="{StaticResource Blue}" FontWeight="Bold"
                                       FontSize="10" FontFamily="{StaticResource FontMono}" Margin="0,14,0,4"/>
                            <ItemsControl x:Name="DetailExtras">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Key}"
                                                       Foreground="{StaticResource Overlay}" Margin="0,0,10,0"
                                                       FontFamily="{StaticResource FontMono}" FontSize="10"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Value}"
                                                       Foreground="{StaticResource Text}" FontSize="10"
                                                       FontFamily="{StaticResource FontMono}" TextWrapping="Wrap"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="5" x:Name="Status" Foreground="{StaticResource Overlay}" FontSize="12"
                   Margin="0,10,0,0"
                   Text="Pick a target directory. SYSTEM services + HighestAvailable tasks + autoElevate manifests are the jackpot vectors."/>
    </Grid>
    <ctrl:LoadingOverlay x:Name="Overlay"/>
    </Grid>
</Page>
