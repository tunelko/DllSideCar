<Window x:Class="DllSidecar.GUI.Views.ReferenceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:models="clr-namespace:DllSidecar.Core.Models;assembly=DllSidecar.Core"
        Title="Reference"
        Width="820" Height="720"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{StaticResource Base}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32" ResizeBorderThickness="6"
                            GlassFrameThickness="0" CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <!-- Oscilloscope grid: 10px minor + 50px major lines, phosphor at low opacity. -->
        <DrawingBrush x:Key="ScopeGrid" TileMode="Tile" Viewport="0,0,50,50" ViewportUnits="Absolute"
                      Stretch="None">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <!-- Dark scope screen base -->
                    <GeometryDrawing Brush="#0B1410">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,50,50"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <!-- Minor grid (every 10px) -->
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#1A4DC58A" Thickness="0.4"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <LineGeometry StartPoint="10,0" EndPoint="10,50"/>
                                <LineGeometry StartPoint="20,0" EndPoint="20,50"/>
                                <LineGeometry StartPoint="30,0" EndPoint="30,50"/>
                                <LineGeometry StartPoint="40,0" EndPoint="40,50"/>
                                <LineGeometry StartPoint="0,10" EndPoint="50,10"/>
                                <LineGeometry StartPoint="0,20" EndPoint="50,20"/>
                                <LineGeometry StartPoint="0,30" EndPoint="50,30"/>
                                <LineGeometry StartPoint="0,40" EndPoint="50,40"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <!-- Major grid (every 50px) -->
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#384DC58A" Thickness="0.8"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <LineGeometry StartPoint="0,0" EndPoint="50,0"/>
                                <LineGeometry StartPoint="0,0" EndPoint="0,50"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- Section "scope screen" card: grid background + phosphor border. -->
        <Style x:Key="ScopeCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ScopeGrid}"/>
            <Setter Property="BorderBrush" Value="#664DC58A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="16,12,16,14"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="H1" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource Phosphor}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="H2" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource Blue}"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>
        <Style x:Key="Body" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="Mono" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Foreground" Value="{StaticResource Subtext}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title strip -->
        <Border Grid.Row="0" Background="{StaticResource Crust}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource HudWindowCloseButton}"
                        Click="Close_Click" ToolTip="Close (Esc)"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="&#x2715;" FontSize="14"/>
                </Button>
                <TextBlock Text="Reference — scoring, columns, quick-start"
                           VerticalAlignment="Center" Margin="14,0,0,0"
                           Foreground="{StaticResource Overlay}" FontSize="11"
                           FontFamily="{StaticResource FontMono}"/>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16,24,16">
            <StackPanel>

                <!-- ── Scoring formula ───────────────────────────────────── -->
                <Border Style="{StaticResource ScopeCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource H1}" Text="1. Scoring formula"/>
                        <TextBlock Style="{StaticResource Body}">
                            <Run Text="Every candidate carries a three-axis score. Each axis is computed independently (one axis never contaminates another) and capped 0..10."/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource Mono}" Margin="0,2,0,8">
                            <Run Text="Total = 0.50 · Exploitability + 0.30 · Impact + 0.20 · Confidence"/>
                        </TextBlock>

                        <TextBlock Style="{StaticResource H2}" Text="Axes"/>
                        <TextBlock Style="{StaticResource Body}">
                            <Run FontWeight="Bold" Text="Exploitability (50%)"/><Run Text=" — write primitive + load certainty + proxy/sideload ease. Bonuses for low-priv writable dir, signed importer, named exports, phantom slot; penalties for SYSTEM32-only forced search, all delay-load, signed target DLL, no importer."/>
                            <LineBreak/>
                            <Run FontWeight="Bold" Text="Impact (30%)"/><Run Text=" — privilege gained if the chain fires. Driven only by PrivescContext.HighestSeverity: Critical=10, High=8, Medium=5, Low=3, Informational=2, None=1."/>
                            <LineBreak/>
                            <Run FontWeight="Bold" Text="Confidence (20%)"/><Run Text=" — evidence quality. Static-only=1 (no importer) or 3 (importer resolved). Upgraded by runtime evidence: RuntimeNameMatch=7/8, RuntimeDirMatch=9/10. Probe-only runtime evidence does NOT upgrade — stays at 3."/>
                        </TextBlock>

                        <TextBlock Style="{StaticResource H2}" Text="Severity bands"/>
                        <TextBlock Style="{StaticResource Mono}">
                            <Run Text="Total 9–10 → Critical"/><LineBreak/>
                            <Run Text="Total 7–8  → High"/><LineBreak/>
                            <Run Text="Total 4–6  → Medium"/><LineBreak/>
                            <Run Text="Total 1–3  → Low"/><LineBreak/>
                            <Run Text="Total 0    → None"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ── Column glossary ───────────────────────────────────── -->
                <Border Style="{StaticResource ScopeCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource H1}" Text="2. Column glossary"/>

                        <TextBlock Style="{StaticResource H2}" Text="Verdict (Analyze · Scan · ProcMon · Runtime)"/>
                        <TextBlock Style="{StaticResource Body}">
                            <Run FontWeight="Bold" Text="REAL"/><Run Text=" — every prerequisite for a planted DLL to execute is confirmed."/><LineBreak/>
                            <Run FontWeight="Bold" Text="LIKELY"/><Run Text=" — most prerequisites met, one or two assumptions remain."/><LineBreak/>
                            <Run FontWeight="Bold" Text="THEORETICAL"/><Run Text=" — sideload primitive exists on paper but key prerequisites unverified or missing."/><LineBreak/>
                            <Run FontWeight="Bold" Text="N/A"/><Run Text=" — sideload not applicable (e.g. KnownDLL, locked dir + no other primitive)."/>
                        </TextBlock>

                        <TextBlock Style="{StaticResource H2}" Text="Mode (ProcMon)"/>
                        <TextBlock Style="{StaticResource Body}">
                            <Run FontWeight="Bold" Text="KNOWN-DLL"/><Run Text=" — kernel32, ntdll, user32, etc. Always loaded from System32 regardless of sideload — never exploitable."/><LineBreak/>
                            <Run FontWeight="Bold" Text="RESOLVABLE"/><Run Text=" — a real system DLL exists somewhere; this PE can be proxied (forwarder chain)."/><LineBreak/>
                            <Run FontWeight="Bold" Text="PHANTOM"/><Run Text=" — no system canonical exists; drop a synthetic DLL into the loader search path."/>
                        </TextBlock>

                        <TextBlock Style="{StaticResource H2}" Text="Writable / Dir"/>
                        <TextBlock Style="{StaticResource Body}">
                            <Run FontWeight="Bold" Text="WRITABLE / OPEN"/><Run Text=" — BUILTIN\Users, Everyone, or AuthenticatedUsers have write; low-priv plant is possible."/><LineBreak/>
                            <Run FontWeight="Bold" Text="USER"/><Run Text=" — only the current user can write (profile dirs like %APPDATA%). Requires user-context."/><LineBreak/>
                            <Run FontWeight="Bold" Text="MIXED"/><Run Text=" — some directories writable, others locked."/><LineBreak/>
                            <Run FontWeight="Bold" Text="LOCKED"/><Run Text=" — admin required (Program Files, System32). Sideload already needs elevation."/>
                        </TextBlock>

                        <TextBlock Style="{StaticResource H2}" Text="Kind (Wizard · Pick)"/>
                        <TextBlock Style="{StaticResource Body}">
                            <Run FontWeight="Bold" Text="EXISTING"/><Run Text=" — a real DLL on disk; generate Proxy mode (forward exports to original)."/><LineBreak/>
                            <Run FontWeight="Bold" Text="PHANTOM"/><Run Text=" — empty slot in the loader search path; generate Sideload mode (synthetic exports)."/><LineBreak/>
                            <Run FontWeight="Bold" Text="IAT / RUNTIME"/><Run Text=" — phantom discovered via static import-table walk (IAT) or via live runtime trace (RUNTIME)."/>
                        </TextBlock>

                        <TextBlock Style="{StaticResource H2}" Text="Access (ProcMon · Runtime · Wizard)"/>
                        <TextBlock Style="{StaticResource Body}">
                            <Run Text="Mirrors ProcMon's "/><Run FontFamily="Consolas" Text="Options:"/><Run Text=" field. Distinguishes a real DLL load attempt from app-internal PATH enumeration. NT constants come from "/><Run FontFamily="Consolas" Text="wdm.h"/><Run Text=" (Windows Internals, Russinovich)."/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource Body}">
                            <Run FontWeight="Bold" Text="{x:Static models:AccessClassLabels.Load}"/>
                            <Run Text=" — combined with "/><Run FontFamily="Consolas" Text="FILE_SYNCHRONOUS_IO_NONALERT (0x20)"/><Run Text=". Loader image-map open: the OS loader is mapping the DLL; a planted file at this path WOULD be executed. Counts as 'dynamically verified'."/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource Body}">
                            <Run FontWeight="Bold" Text="{x:Static models:AccessClassLabels.Probe}"/>
                            <Run Text=" — value 0x200000. Metadata-only probe ("/><Run FontFamily="Consolas" Text="GetFileAttributes"/><Run Text=" / "/><Run FontFamily="Consolas" Text="PathFileExists"/><Run Text=" / "/><Run FontFamily="Consolas" Text="FindFirstFile"/><Run Text=" class). The application is querying file metadata, not mapping it; a planted DLL here would NOT execute. Does NOT count as verified — Confidence stays at the static floor."/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource Body}">
                            <Run FontWeight="Bold" Text="{x:Static models:AccessClassLabels.Mixed}"/>
                            <Run Text=" — at least one real load alongside probe events for the same DLL."/>
                        </TextBlock>

                        <TextBlock Style="{StaticResource H2}" Text="Score columns (Wizard · Pick)"/>
                        <TextBlock Style="{StaticResource Body}">
                            <Run FontWeight="Bold" Text="Total"/><Run Text=" — weighted average (0.5·Exploit + 0.3·Impact + 0.2·Conf), the default ranking key."/><LineBreak/>
                            <Run FontWeight="Bold" Text="Exploit / Impact / Conf"/><Run Text=" — the three axes individually. Click a header to sort by one axis."/><LineBreak/>
                            <Run FontWeight="Bold" Text="Privesc"/><Run Text=" — short label of the highest-severity privesc vector found (e.g. Task, Service, AutoElevate)."/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ── Quick-start ───────────────────────────────────────── -->
                <Border Style="{StaticResource ScopeCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource H1}" Text="3. Quick-start workflows"/>
                        <TextBlock Style="{StaticResource Body}">
                            <Run Text="Pick a workflow based on what you have. The wizard glues them together if you need the full pipeline."/>
                        </TextBlock>

                        <TextBlock Style="{StaticResource H2}" Text="A. Inspect a single DLL"/>
                        <TextBlock Style="{StaticResource Body}">
                            <Run Text="1. Open "/><Run FontWeight="Bold" Text="Analyze"/><Run Text=" from the sidebar."/><LineBreak/>
                            <Run Text="2. Browse or drop a "/><Run FontFamily="Consolas" Text="*.dll"/><Run Text=" / "/><Run FontFamily="Consolas" Text="*.exe"/><Run Text=" path."/><LineBreak/>
                            <Run Text="3. Review the right-hand cards: PE headers, security flags (ASLR/DEP/CFG), version info, exports table, signing."/><LineBreak/>
                            <Run Text="4. Use the VerdictBadge at the top to see whether this binary is a viable sideload host."/>
                        </TextBlock>

                        <TextBlock Style="{StaticResource H2}" Text="B. Scan a directory for sideload candidates"/>
                        <TextBlock Style="{StaticResource Body}">
                            <Run Text="1. Open "/><Run FontWeight="Bold" Text="Scan"/><Run Text=" from the sidebar."/><LineBreak/>
                            <Run Text="2. Pick the install directory of the target software (e.g. "/><Run FontFamily="Consolas" Text="C:\Program Files\Vendor\App"/><Run Text=")."/><LineBreak/>
                            <Run Text="3. Filter by Verdict (Real / Likely first), Writability (WRITABLE), or Kind."/><LineBreak/>
                            <Run Text="4. Double-click any row to hop into Analyze on that DLL."/><LineBreak/>
                            <Run Text="5. Right-click → 'Generate Sideload PoC' to hand a candidate off to DLL Techniques."/>
                        </TextBlock>

                        <TextBlock Style="{StaticResource H2}" Text="C. Capture runtime evidence (recommended for ground truth)"/>
                        <TextBlock Style="{StaticResource Body}">
                            <Run Text="1. Open "/><Run FontWeight="Bold" Text="Runtime Trace"/><Run Text=" from the sidebar."/><LineBreak/>
                            <Run Text="2. Pick a mode: "/><Run FontWeight="Bold" Text="Launch"/><Run Text=" (start a fresh exe), "/><Run FontWeight="Bold" Text="Attach"/><Run Text=" (target a running PID), or "/><Run FontWeight="Bold" Text="Watch by name"/><Run Text=" (for services that restart)."/><LineBreak/>
                            <Run Text="3. Press "/><Run FontWeight="Bold" Text="Start"/><Run Text=", reproduce the user action you care about (open a file, run a command), then "/><Run FontWeight="Bold" Text="Stop"/><Run Text="."/><LineBreak/>
                            <Run Text="4. Look at the "/><Run FontWeight="Bold" Text="Access"/><Run Text=" column: "/><Run FontFamily="Consolas" Text="{x:Static models:AccessClassLabels.Load}"/><Run Text=" rows are exploitable; "/><Run FontFamily="Consolas" Text="{x:Static models:AccessClassLabels.Probe}"/><Run Text=" rows are app-internal noise."/><LineBreak/>
                            <Run Text="5. "/><Run FontWeight="Bold" Text="Promote to Wizard / Scan"/><Run Text=" to feed the captured phantoms into the rest of the pipeline."/>
                        </TextBlock>

                        <TextBlock Style="{StaticResource H2}" Text="D. Ingest a ProcMon CSV (offline trace)"/>
                        <TextBlock Style="{StaticResource Body}">
                            <Run Text="1. In ProcMon, apply the filter: "/><Run FontFamily="Consolas" Text="Operation = CreateFile, Result = NAME NOT FOUND, Path ends with .dll"/><Run Text="."/><LineBreak/>
                            <Run Text="2. File → Save → CSV. Make sure 'Apply display filter' is checked."/><LineBreak/>
                            <Run Text="3. In DllSidecar, open "/><Run FontWeight="Bold" Text="ProcMon"/><Run Text=" from the sidebar, browse the CSV, press Parse."/><LineBreak/>
                            <Run Text="4. Same "/><Run FontWeight="Bold" Text="Access"/><Run Text=" column logic applies — "/><Run FontFamily="Consolas" Text="{x:Static models:AccessClassLabels.Probe}"/><Run Text=" rows do NOT execute a planted DLL even though they show NAME NOT FOUND."/><LineBreak/>
                            <Run Text="5. Select a row → "/><Run FontWeight="Bold" Text="Promote to DLL Techniques"/><Run Text=" to generate PoC source."/>
                        </TextBlock>

                        <TextBlock Style="{StaticResource H2}" Text="E. Full pipeline (Wizard)"/>
                        <TextBlock Style="{StaticResource Body}">
                            <Run Text="The wizard chains everything: "/><Run FontWeight="Bold" Text="Input"/><Run Text=" (pick a target dir or runtime entry) → "/><Run FontWeight="Bold" Text="Survey"/><Run Text=" (review phantoms + privesc context) → "/><Run FontWeight="Bold" Text="Pick"/><Run Text=" (rank by Total, filter by Access / Privesc / Dir) → "/><Run FontWeight="Bold" Text="Craft"/><Run Text=" (Tracer / Proxy / Sideload generation) → "/><Run FontWeight="Bold" Text="Verify"/><Run Text=" (compile + DLL inspector) → "/><Run FontWeight="Bold" Text="Report"/><Run Text=" (advisory template)."/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ── Tips ──────────────────────────────────────────────── -->
                <Border Style="{StaticResource ScopeCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource H1}" Text="4. Tips"/>
                        <TextBlock Style="{StaticResource Body}">
                            <Run Text="• "/><Run FontWeight="Bold" Text="Hover any column header"/><Run Text=" for a per-column tooltip with NT-level details."/><LineBreak/>
                            <Run Text="• "/><Run FontWeight="Bold" Text="File → Open Session"/><Run Text=" restores the last saved session (paths + page + ETW trace + wizard state)."/><LineBreak/>
                            <Run Text="• "/><Run FontWeight="Bold" Text="Ctrl+B"/><Run Text=" collapses/expands the sidebar."/><LineBreak/>
                            <Run Text="• The "/><Run FontWeight="Bold" Text="console"/><Run Text=" panel at the bottom shows every action (parse, scan, score) — drag the splitter to expand it."/>
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="18,8,18,18">
            <Button Content="Close" Style="{StaticResource SecondaryButton}" IsCancel="True" IsDefault="True"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
