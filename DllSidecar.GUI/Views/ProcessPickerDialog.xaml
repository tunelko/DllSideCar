<Window x:Class="DllSidecar.GUI.Views.ProcessPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Attach to process — pick a running PID"
        Width="900" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Base}"
        FontFamily="{StaticResource FontSans}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">
    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Pick a running process"
                       FontSize="20" FontWeight="Bold" Foreground="{StaticResource Text}"/>
            <TextBlock FontSize="11" Foreground="{StaticResource Overlay}" Margin="0,4,0,0" TextWrapping="Wrap"
                       Text="Process tree (parent → children). Click +/− to expand or collapse a branch. Double-click a row, or select and press Attach."/>
        </StackPanel>

        <!-- Filter + refresh -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="FilterBox" Grid.Column="0"
                     FontFamily="Cascadia Mono,Consolas" FontSize="11" Padding="6,4"
                     ToolTip="Filter by name, PID, or window title — branches with no match are hidden, ancestors are kept for context"
                     TextChanged="Filter_Changed"/>
            <Border Grid.Column="1" Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                    BorderThickness="1" CornerRadius="6" Margin="12,0,0,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <CheckBox x:Name="ChkWithWindow" Style="{StaticResource SegmentedCheck}"
                              Content="Only with window" IsChecked="True"
                              Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <CheckBox x:Name="ChkCurrentSession" Style="{StaticResource SegmentedCheck}"
                              Content="This session" IsChecked="True"
                              Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                </StackPanel>
            </Border>
            <Button x:Name="RefreshBtn" Grid.Column="2" Content="Refresh"
                    Style="{StaticResource SecondaryButton}" Margin="12,0,0,0"
                    Click="Refresh_Click"/>
        </Grid>

        <!-- Process tree -->
        <Border Grid.Row="2" Background="{StaticResource Mantle}" CornerRadius="6" Padding="6">
            <DockPanel>
                <!-- Column headers (only for the root row offset; children align within their own grid) -->
                <Grid DockPanel.Dock="Top" Background="{StaticResource Surface1}" Margin="18,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="PID" Foreground="{StaticResource Subtext}"
                               FontFamily="Cascadia Mono,Consolas" FontSize="10" FontWeight="SemiBold" Padding="6,4"/>
                    <TextBlock Grid.Column="1" Text="Name" Foreground="{StaticResource Subtext}"
                               FontFamily="Cascadia Mono,Consolas" FontSize="10" FontWeight="SemiBold" Padding="6,4"/>
                    <TextBlock Grid.Column="2" Text="Window title" Foreground="{StaticResource Subtext}"
                               FontFamily="Cascadia Mono,Consolas" FontSize="10" FontWeight="SemiBold" Padding="6,4"/>
                    <TextBlock Grid.Column="3" Text="Session" Foreground="{StaticResource Subtext}"
                               FontFamily="Cascadia Mono,Consolas" FontSize="10" FontWeight="SemiBold" Padding="6,4"
                               HorizontalAlignment="Right"/>
                </Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <TreeView x:Name="Tree" Background="Transparent" BorderThickness="0"
                              Foreground="{StaticResource Text}" FontFamily="Cascadia Mono,Consolas"
                              FontSize="11" SelectedItemChanged="Tree_SelectedChanged"
                              MouseDoubleClick="Tree_DoubleClick"
                              ItemContainerStyle="{StaticResource BoxedTreeViewItem}">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <Grid Margin="0,1,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*" MinWidth="120"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Info.Pid}"
                                               Foreground="{StaticResource Overlay}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Info.Name}"
                                               Foreground="{StaticResource Text}" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Info.Title}"
                                               Foreground="{StaticResource Subtext}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Info.Session}"
                                               Foreground="{StaticResource Overlay}"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <TextBlock x:Name="Status" HorizontalAlignment="Left" VerticalAlignment="Center"
                       Foreground="{StaticResource Overlay}" FontSize="11"
                       FontFamily="Cascadia Mono,Consolas"/>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                        Click="Cancel_Click" IsCancel="True"/>
                <Button x:Name="OkBtn" Content="Attach" Style="{StaticResource AccentButton}"
                        Margin="8,0,0,0" Click="Ok_Click" IsDefault="True" IsEnabled="False"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
