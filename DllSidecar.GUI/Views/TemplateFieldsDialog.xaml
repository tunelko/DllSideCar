<Window x:Class="DllSidecar.GUI.Views.TemplateFieldsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Template fields"
        Width="820" Height="760"
        MinWidth="700" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource Base}"
        FontFamily="{StaticResource FontSans}">
    <Grid Margin="24,18,24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock x:Name="HeaderTitle" Text="Template fields" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource Text}"/>
            <TextBlock x:Name="HeaderSub" FontSize="12" Foreground="{StaticResource Overlay}"
                       Margin="0,4,0,0" TextWrapping="Wrap"
                       Text="Editable fields for the selected template. Values you set here feed the renderer when you Save to Library — empty fields fall back to placeholder hints in the rendered output."/>
        </StackPanel>

        <!-- Form body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Attack type + Impact category -->
                <StackPanel x:Name="RowAttackImpact" Margin="0,0,0,14">
                    <TextBlock Text="CLASSIFICATION" Foreground="{StaticResource Blue}" FontWeight="Bold"
                               FontSize="10" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Attack type" Foreground="{StaticResource Subtext}" FontSize="11" Margin="0,0,0,3"/>
                            <ComboBox x:Name="CbAttackType" Height="26">
                                <ComboBoxItem Content="Local"/>
                                <ComboBoxItem Content="Remote"/>
                                <ComboBoxItem Content="Physical"/>
                                <ComboBoxItem Content="ContextDependent"/>
                                <ComboBoxItem Content="Other"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Impact category" Foreground="{StaticResource Subtext}" FontSize="11" Margin="0,0,0,3"/>
                            <ComboBox x:Name="CbImpact" Height="26">
                                <ComboBoxItem Content="CodeExecution"/>
                                <ComboBoxItem Content="DenialOfService"/>
                                <ComboBoxItem Content="EscalationOfPrivileges"/>
                                <ComboBoxItem Content="InformationDisclosure"/>
                                <ComboBoxItem Content="Other"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Vulnerability type text -->
                <StackPanel x:Name="RowVulnType" Margin="0,0,0,14">
                    <TextBlock Text="VULNERABILITY TYPE (FREE TEXT)" Foreground="{StaticResource Blue}" FontWeight="Bold"
                               FontSize="10" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                    <TextBox x:Name="TbVulnType" Padding="8,6" FontSize="12"/>
                    <TextBlock Foreground="{StaticResource Overlay}" FontSize="10" Margin="0,3,0,0" TextWrapping="Wrap"
                               Text="INCIBE: this is the text that appears next to the 'Other or unknown' checkbox."/>
                </StackPanel>

                <!-- Vendor POC -->
                <StackPanel x:Name="RowVendorPoc" Margin="0,0,0,14">
                    <TextBlock Text="VENDOR POC" Foreground="{StaticResource Blue}" FontWeight="Bold"
                               FontSize="10" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Name" Foreground="{StaticResource Subtext}" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox x:Name="TbPocName" Padding="8,6" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Email" Foreground="{StaticResource Subtext}" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox x:Name="TbPocEmail" Padding="8,6" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Affected components -->
                <StackPanel x:Name="RowAffected" Margin="0,0,0,14">
                    <TextBlock Text="AFFECTED COMPONENTS" Foreground="{StaticResource Blue}" FontWeight="Bold"
                               FontSize="10" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                    <TextBox x:Name="TbAffected" MinHeight="72" MaxHeight="140"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             FontFamily="Cascadia Mono,Consolas" FontSize="11" Padding="8,6"
                             VerticalScrollBarVisibility="Auto"/>
                    <TextBlock Foreground="{StaticResource Overlay}" FontSize="10" Margin="0,3,0,0"
                               Text="One component per line. The renderer converts to '  - entry' bullets."/>
                </StackPanel>

                <!-- Previous requirements -->
                <StackPanel x:Name="RowRequirements" Margin="0,0,0,14">
                    <TextBlock Text="PREVIOUS REQUIREMENTS" Foreground="{StaticResource Blue}" FontWeight="Bold"
                               FontSize="10" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                    <TextBox x:Name="TbRequirements" MinHeight="72" MaxHeight="140"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             FontFamily="Cascadia Mono,Consolas" FontSize="11" Padding="8,6"
                             VerticalScrollBarVisibility="Auto"/>
                    <TextBlock Foreground="{StaticResource Overlay}" FontSize="10" Margin="0,3,0,0"
                               Text="One precondition per line (e.g. 'local standard user', 'write access to %TEMP%')."/>
                </StackPanel>

                <!-- Proposed solution -->
                <StackPanel x:Name="RowSolution" Margin="0,0,0,14">
                    <TextBlock Text="PROPOSED SOLUTION" Foreground="{StaticResource Blue}" FontWeight="Bold"
                               FontSize="10" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                    <TextBox x:Name="TbSolution" MinHeight="100" MaxHeight="200"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             FontFamily="Cascadia Mono,Consolas" FontSize="11" Padding="8,6"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>

                <!-- CVSS v4 -->
                <StackPanel x:Name="RowCvssV4" Margin="0,0,0,4">
                    <TextBlock Text="CVSS 4.0" Foreground="{StaticResource Blue}" FontWeight="Bold"
                               FontSize="10" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Vector" Foreground="{StaticResource Subtext}" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox x:Name="TbV4Vector" Padding="8,6" FontSize="11"
                                     FontFamily="Cascadia Mono,Consolas"
                                     ToolTip="Paste from https://www.first.org/cvss/calculator/4.0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Score" Foreground="{StaticResource Subtext}" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox x:Name="TbV4Score" Padding="8,6" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Foreground="{StaticResource Overlay}" FontSize="10" Margin="0,3,0,0" TextWrapping="Wrap"
                               Text="Vector authoritative; score approximate. For submission, verify against the FIRST online calculator."/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="ActiveLabel" Foreground="{StaticResource Overlay}"
                       FontSize="11" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Cancel" Style="{StaticResource SecondaryButton}" IsCancel="True" Click="Cancel_Click"/>
                <Button Content="Apply" Style="{StaticResource AccentButton}" IsDefault="True"
                        Margin="10,0,0,0" Click="Apply_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
