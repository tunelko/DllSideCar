<Window x:Class="DllSidecar.GUI.Views.ServiceAuditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SYSTEM service audit — pick a target binary to scan"
        Width="1180" Height="680"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Base}"
        FontFamily="{StaticResource FontSans}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">
    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="SYSTEM service audit"
                       FontSize="20" FontWeight="Bold" Foreground="{StaticResource Text}"/>
            <TextBlock FontSize="11" Foreground="{StaticResource Overlay}" Margin="0,4,0,0" TextWrapping="Wrap"
                       Text="Machine-wide enumeration of registered services. Pick one and send its ServiceDll (svchost-hosted) or ImagePath (dedicated process) into AnalyzePage to scan its loader callsites — the static side of the SandboxEscaper-style audit."/>
        </StackPanel>

        <!-- Filter + checkboxes + refresh -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="FilterBox" Grid.Column="0"
                     FontFamily="{StaticResource FontMono}" FontSize="11" Padding="6,4"
                     ToolTip="Filter by service name, display name, image, ServiceDll, or account"
                     TextChanged="Filter_Changed"/>
            <Border Grid.Column="1" Background="{StaticResource Mantle}" BorderBrush="{StaticResource Ring}"
                    BorderThickness="1" CornerRadius="6" Margin="12,0,0,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <CheckBox x:Name="ChkLocalSystem" Style="{StaticResource SegmentedCheck}"
                              Content="LocalSystem only" IsChecked="True"
                              Checked="Filter_Changed" Unchecked="Filter_Changed"
                              ToolTip="Show only services running as LocalSystem (highest privilege target)"/>
                    <CheckBox x:Name="ChkRunningOnly" Style="{StaticResource SegmentedCheck}"
                              Content="Running only" IsChecked="True"
                              Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <CheckBox x:Name="ChkSvcDllOnly" Style="{StaticResource SegmentedCheck}"
                              Content="Has ServiceDll" IsChecked="False"
                              Checked="Filter_Changed" Unchecked="Filter_Changed"
                              ToolTip="Limit to svchost-hosted services (the ones with a ServiceDll registry value)"/>
                    <CheckBox x:Name="ChkHideDrivers" Style="{StaticResource SegmentedCheck}"
                              Content="Hide drivers" IsChecked="True"
                              Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                </StackPanel>
            </Border>
            <Button x:Name="RefreshBtn" Grid.Column="2" Content="Refresh"
                    Style="{StaticResource SecondaryButton}" Margin="12,0,0,0"
                    Click="Refresh_Click"/>
        </Grid>

        <!-- Service grid -->
        <Border Grid.Row="2" Background="{StaticResource Mantle}" CornerRadius="6" Padding="6">
            <DataGrid x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                      Background="Transparent" Foreground="{StaticResource Text}" BorderThickness="0"
                      RowBackground="{StaticResource Surface0}" AlternatingRowBackground="#3B3B52"
                      GridLinesVisibility="None" HeadersVisibility="Column"
                      FontFamily="{StaticResource FontMono}" FontSize="11"
                      SelectionMode="Single" RowHeight="26"
                      SelectionChanged="Grid_SelectionChanged"
                      MouseDoubleClick="Grid_DoubleClick"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{StaticResource Surface1}"/>
                        <Setter Property="Foreground" Value="{StaticResource Subtext}"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Service"      Binding="{Binding Name}"           Width="160"/>
                    <DataGridTextColumn Header="Display name" Binding="{Binding DisplayName}"    Width="220"/>
                    <DataGridTextColumn Header="Account"      Binding="{Binding AccountText}"    Width="140"/>
                    <DataGridTextColumn Header="State"        Binding="{Binding StateText}"      Width="80"/>
                    <DataGridTextColumn Header="Image"        Binding="{Binding ImageFile}"      Width="160"/>
                    <DataGridTextColumn Header="ServiceDll"   Binding="{Binding ServiceDllFile}" Width="*"
                                        ElementStyle="{StaticResource AxisExploitCell}"
                                        ToolTipService.ToolTip="The DLL that actually implements this service (svchost-hosted only). The principal target for static loader-callsite analysis."/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <TextBlock x:Name="Status" HorizontalAlignment="Left" VerticalAlignment="Center"
                       Foreground="{StaticResource Overlay}" FontSize="11"
                       FontFamily="{StaticResource FontMono}"/>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                        Click="Cancel_Click" IsCancel="True"/>
                <Button x:Name="AnalyzeImageBtn" Content="Analyze Image"
                        Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                        Click="AnalyzeImage_Click" IsEnabled="False"
                        ToolTip="Open AnalyzePage on the service's executable (e.g. svchost.exe, splunkd.exe)"/>
                <Button x:Name="AnalyzeDllBtn" Content="Analyze ServiceDll"
                        Style="{StaticResource AccentButton}" Margin="8,0,0,0"
                        Click="AnalyzeDll_Click" IsEnabled="False" IsDefault="True"
                        ToolTip="Open AnalyzePage on the service's implementation DLL (svchost-hosted services). Hit 🔬 Callsites there to find LoadLibrary patterns."/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
