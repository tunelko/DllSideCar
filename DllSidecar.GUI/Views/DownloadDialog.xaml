<Window x:Class="DllSidecar.GUI.Views.DownloadDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Install tool"
        Width="620" Height="480"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Base}"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="ToolTitle" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource Text}"/>
        <TextBlock Grid.Row="1" x:Name="ToolSubtitle" FontSize="12" FontFamily="Cascadia Mono,Consolas"
                   Foreground="{StaticResource Overlay}" Margin="0,4,0,16" TextWrapping="Wrap"/>

        <!-- Phase label -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="PhaseLabel" Text="Ready"
                       Foreground="{StaticResource Blue}" FontWeight="Bold" FontSize="11"/>
            <TextBlock Grid.Column="1" x:Name="PercentLabel" Text=""
                       Foreground="{StaticResource Subtext}" FontFamily="Cascadia Mono,Consolas" FontSize="11"/>
        </Grid>

        <!-- Progress bar -->
        <ProgressBar Grid.Row="3" x:Name="ProgressBar" Height="6" Margin="0,6,0,12"
                     Background="{StaticResource Surface0}" Foreground="{StaticResource Blue}"
                     BorderThickness="0" Minimum="0" Maximum="100" Value="0"/>

        <!-- Log -->
        <Border Grid.Row="4" Background="{StaticResource Mantle}" CornerRadius="6" Padding="12,10">
            <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="LogBox" IsReadOnly="True" Background="Transparent"
                         Foreground="{StaticResource Text}" BorderThickness="0"
                         FontFamily="Cascadia Mono,Consolas" FontSize="11"
                         TextWrapping="Wrap" AcceptsReturn="True"/>
            </ScrollViewer>
        </Border>

        <!-- Actions -->
        <Grid Grid.Row="5" Margin="0,14,0,0">
            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                <TextBlock x:Name="SecurityNote"
                           Text="Will verify Authenticode signature of downloaded binaries"
                           Foreground="{StaticResource Overlay}" FontSize="10"
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button x:Name="CancelBtn" Content="Cancel" Style="{StaticResource SecondaryButton}"
                        Click="Cancel_Click"/>
                <Button x:Name="InstallBtn" Content="Install" Style="{StaticResource PrimaryButton}"
                        Margin="10,0,0,0" Click="Install_Click"/>
                <Button x:Name="CloseBtn" Content="Close" Style="{StaticResource SecondaryButton}"
                        Click="Close_Click" Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
