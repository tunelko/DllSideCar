<UserControl x:Class="DllSidecar.GUI.Controls.LoadingOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed"
             IsHitTestVisible="True">
    <!-- Semi-transparent scrim blocks clicks while visible -->
    <Grid Background="#CC1E1E2E">
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{StaticResource Mantle}" CornerRadius="10" Padding="28,22">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.5" Color="Black"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <!-- Spinner: dashed ellipse with continuous rotation -->
                <Grid Width="32" Height="32" VerticalAlignment="Center">
                    <Ellipse Stroke="{StaticResource Surface2}" StrokeThickness="3"/>
                    <Ellipse x:Name="Spinner" Stroke="{StaticResource Blue}" StrokeThickness="3"
                             StrokeDashArray="6 60" StrokeDashCap="Round"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="SpinRot" Angle="0"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="SpinRot"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="360" Duration="0:0:1.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </Grid>
                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" Text="Working..."
                               Foreground="{StaticResource Text}" FontWeight="Bold" FontSize="14"/>
                    <TextBlock x:Name="SubtitleText" Text=""
                               Foreground="{StaticResource Overlay}" FontSize="11" Margin="0,3,0,0"
                               MaxWidth="320" TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
