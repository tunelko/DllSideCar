<UserControl x:Class="DllSidecar.GUI.Controls.ToolPathRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Margin="0,4,0,4">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header row: label + status pill -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock x:Name="LabelText" Text="Tool"
                       FontSize="11" FontWeight="SemiBold"
                       FontFamily="{StaticResource FontMono}"
                       Foreground="{StaticResource Subtext}"
                       VerticalAlignment="Center"/>
            <Border Background="{StaticResource Surface0}" CornerRadius="999"
                    Padding="7,1" Margin="8,0,0,0" VerticalAlignment="Center">
                <TextBlock x:Name="StatusPill" Text="?" FontSize="9" FontWeight="Bold"
                           FontFamily="{StaticResource FontBadge}"
                           Foreground="{StaticResource Subtext}"/>
            </Border>
            <TextBlock x:Name="PurposeText" Text=""
                       FontSize="10" Margin="10,0,0,0"
                       Foreground="{StaticResource Overlay}" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" MaxWidth="380"/>
        </StackPanel>

        <!-- Path input + buttons -->
        <TextBox x:Name="PathBox" Grid.Row="1" Grid.Column="0"
                 FontFamily="{StaticResource FontMono}" FontSize="11"
                 TextChanged="PathBox_TextChanged"/>
        <Button x:Name="BrowseBtn" Grid.Row="1" Grid.Column="1" Content="&#x1F4C1;"
                Style="{StaticResource IconButton}" Margin="6,0,0,0"
                Click="Browse_Click" ToolTip="Browse"/>
        <Button x:Name="DetectBtn" Grid.Row="1" Grid.Column="2" Content="Detect"
                Style="{StaticResource SecondaryButton}" Margin="6,0,0,0"
                Click="Detect_Click" ToolTip="Auto-detect from Sysinternals folder, ToolsRoot, or PATH"/>
        <Button x:Name="OpenLinkBtn" Grid.Row="1" Grid.Column="3" Content="&#x2197;"
                Style="{StaticResource IconButton}" Margin="6,0,0,0"
                Click="OpenLink_Click" ToolTip="Open download page"
                Visibility="Collapsed"/>
    </Grid>
</UserControl>
