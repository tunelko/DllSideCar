<UserControl x:Class="DllSidecar.GUI.Controls.VerdictBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <!-- Compact "[TIER N/10]" chip; bg/fg set from code-behind. -->
    <Border x:Name="BadgeBorder" CornerRadius="3" Padding="8,2"
            VerticalAlignment="Center" HorizontalAlignment="Left">
        <Border.ToolTip>
            <ToolTip Background="{StaticResource Mantle}" BorderBrush="{StaticResource RingStrong}"
                     BorderThickness="1" Padding="12,10">
                <StackPanel MaxWidth="420">
                    <TextBlock x:Name="TipTitle" FontWeight="Bold" FontSize="12"
                               Foreground="{StaticResource Text}"/>
                    <TextBlock x:Name="TipBlocker" FontSize="11" Foreground="{StaticResource Red}"
                               TextWrapping="Wrap" Margin="0,6,0,0" Visibility="Collapsed"/>
                    <TextBlock Text="PROS" FontFamily="{StaticResource FontBadge}" FontWeight="Bold"
                               FontSize="9" Foreground="{StaticResource Phosphor}" Margin="0,10,0,3"/>
                    <ItemsControl x:Name="TipPros">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}" FontSize="11"
                                           Foreground="{StaticResource Text}"
                                           TextWrapping="Wrap" Margin="0,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="CONS" FontFamily="{StaticResource FontBadge}" FontWeight="Bold"
                               FontSize="9" Foreground="{StaticResource Red}" Margin="0,8,0,3"/>
                    <ItemsControl x:Name="TipCons">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}" FontSize="11"
                                           Foreground="{StaticResource Subtext}"
                                           TextWrapping="Wrap" Margin="0,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ToolTip>
        </Border.ToolTip>
        <TextBlock x:Name="BadgeText" FontSize="10" FontWeight="Bold"
                   FontFamily="{StaticResource FontBadge}"/>
    </Border>
</UserControl>
