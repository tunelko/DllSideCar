# EditorConfig for DllSidecar
# Root: stop walking up
root = true

[*]
indent_style = space
indent_size = 4
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{xaml,csproj,props,targets}]
indent_size = 2

[*.{yml,yaml,json}]
indent_size = 2
end_of_line = lf

# ---------------------------------------------------------------------------
# Roslyn analyzer severities — only security rules are promoted to ERROR.
# Style/quality stays at suggestion so dev iteration isn't blocked.
# ---------------------------------------------------------------------------

[*.cs]
# --- .NET CA security rules → ERROR ---------------------------------------
# CA2100: SQL queries built from string concatenation (we use SQLite!)
dotnet_diagnostic.CA2100.severity = error
# CA2109: Review visible event handlers
dotnet_diagnostic.CA2109.severity = error
# CA2153: Do NOT catch corrupted state exceptions
dotnet_diagnostic.CA2153.severity = error
# CA3001-CA3076: web injections (XSS, XPath, XML, LDAP, command, regex)
dotnet_diagnostic.CA3001.severity = error
dotnet_diagnostic.CA3002.severity = error
dotnet_diagnostic.CA3003.severity = error
dotnet_diagnostic.CA3004.severity = error
