# --- Default for the rest (style/quality) → suggestion --------------------
# Don't flood the build log with noise; security is the gate, not formatting.
dotnet_analyzer_diagnostic.severity = suggestion

# ---------------------------------------------------------------------------
# Targeted suppressions (with justification) for the security rules above.
# Each entry says WHY the elevated rule is downgraded for a specific file.
# ---------------------------------------------------------------------------

# AdvisoryRepository.cs — CA2100 fires on CommandText assignments that are
# string literals (often a ternary between two hardcoded queries). No user
# input is ever concatenated into SQL; every variable goes through SqliteCommand
# parameters ($id, $vendor, etc.). Reviewed manually.
[**/AdvisoryRepository.cs]
dotnet_diagnostic.CA2100.severity = none

# TemplateConfig.cs — Random.Shared.Next is used to seed the XOR byte for the
# generated PoC C payload (didactic obfuscation, not security material).
# A non-crypto RNG is appropriate — the value is embedded in the source we
# emit and is meant to be inspectable.
[**/TemplateConfig.cs]
dotnet_diagnostic.CA5394.severity = none
dotnet_diagnostic.SCS0005.severity = none

# AdvisoryLibraryPage.xaml.cs — SCS0018 (Zip Slip) is mitigated explicitly:
# entry.Name is reduced to Path.GetFileName(...) and the resolved destination
# is verified to start with the tempDir prefix before ExtractToFile. The taint
# tracker can't see through the sanitization, so it still flags. Reviewed.
[**/AdvisoryLibraryPage.xaml.cs]
dotnet_diagnostic.SCS0018.severity = none
